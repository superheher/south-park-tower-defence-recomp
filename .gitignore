# Copyrighted / derived game data — never commit
/extracted/
/private/
*.xex
*.xexp
default.xex
assets/

# Generated recompiler output (reproducible from XEX + config) — but keep the
# small static rexglue.cmake glue (SDK find + codegen target), which `rexglue init`
# cannot regenerate without clobbering the committed CMakeLists/manifest/presets.
/generated/*
!/generated/rexglue.cmake
/ppc/
/out/
*.gen.cpp
*.gen.h

# Build
/build/
**/build/
/cmake-build-*/
*.o
*.obj
*.exe
*.pdb

# Runtime diagnostics (from the crash handler / logging)
crash_backtrace.txt
*.log

# OS / editor
.DS_Store
Thumbs.db
.vs/
.vscode/
.idea/
