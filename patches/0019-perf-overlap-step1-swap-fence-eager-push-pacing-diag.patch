-  IssueSwap(frontbuffer_ptr, frontbuffer_width, frontbuffer_height);
+  {  // [pacing-diag] TEMP v2.1: present-path share of the CP frame slot
+    uint64_t st0 = rex::chrono::Clock::QueryHostTickCount();
