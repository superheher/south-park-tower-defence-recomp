From a4367aa66741fb3b02cb098122cd075a67a47d3d Mon Sep 17 00:00:00 2001
From: superheher <heh@vivaldi.net>
Date: Sat, 30 May 2026 16:22:03 +0300
Subject: [PATCH 05/13] graphics: command-processor boot/present/fence fixes
 (RefreshVblankFence, WAIT_REG_MEM)


diff --git a/include/rex/graphics/command_processor.h b/include/rex/graphics/command_processor.h
index 6998a45..af1546f 100644
--- a/include/rex/graphics/command_processor.h
+++ b/include/rex/graphics/command_processor.h
@@ -37,6 +37,15 @@ class ByteStream;
 
 namespace rex::graphics {
 
+// Host tick of the most recent graphics-pipeline (shader) creation. Set by the
+// pipeline cache; read by the command processor's frame limiter to detect "level
+// loading" (heavy shader compilation) and avoid throttling then. Inline so there
+// is a single shared instance across the runtime without a separate definition.
+inline std::atomic<uint64_t>& LastPipelineHostTick() {
+  static std::atomic<uint64_t> tick{0};
+  return tick;
+}
+
 class GraphicsSystem;
 class Shader;
 
@@ -87,6 +96,9 @@ class CommandProcessor {
 
   uint32_t counter() const { return counter_; }
   void increment_counter() { counter_++; }
+  // [recomp fix] Refresh the guest's GPU-vblank-counter fence (last EVENT_WRITE_SHD counter write)
+  // with the live counter_ on each vblank, so the guest sees progress between packets. See .cpp.
+  void RefreshVblankFence();
 
   Shader* active_vertex_shader() const { return active_vertex_shader_; }
   Shader* active_pixel_shader() const { return active_pixel_shader_; }
@@ -270,6 +282,9 @@ class CommandProcessor {
   std::vector<uint32_t> me_bin_;
 
   uint32_t counter_ = 0;
+  // [recomp fix] Last EVENT_WRITE_SHD GPU-vblank-counter fence target, refreshed each vblank.
+  uint32_t vblank_fence_addr_ = 0;
+  xenos::Endian vblank_fence_endian_ = xenos::Endian::kNone;
 
   uint32_t primary_buffer_ptr_ = 0;
   uint32_t primary_buffer_size_ = 0;
diff --git a/src/graphics/command_processor.cpp b/src/graphics/command_processor.cpp
index 60efcd3..7ed8470 100644
--- a/src/graphics/command_processor.cpp
+++ b/src/graphics/command_processor.cpp
@@ -10,6 +10,7 @@
  */
 
 #include <algorithm>
+#include <chrono>
 #include <cinttypes>
 #include <cmath>
 #include <cstring>
@@ -37,9 +38,18 @@
 
 REXCVAR_DEFINE_BOOL(vsync, true, "GPU", "Enable vertical sync");
 
-REXCVAR_DEFINE_BOOL(clear_memory_page_state, true, "GPU",
+REXCVAR_DEFINE_BOOL(clear_memory_page_state, false, "GPU",
                     "Refresh page-valid state from GPU-written memory at frame end. "
-                    "Disable for minor CPU overhead reduction, but may break memory coherency.")
+                    "[recomp: defaulted OFF — KB 65 / rexglue-sdk #341] When ON, this skip-upload "
+                    "optimization intermittently keeps per-frame CPU-rasterized dynamic glyph pages "
+                    "marked already-valid and skips their re-upload -> the GPU samples stale bytes "
+                    "-> vertical-striped text that varies every visit (in-match hints, menu "
+                    "difficulty labels, results SCORE/BONUS/TOTAL). The #341 full-copy fix and the "
+                    "shared_memory.cpp read lock make the ON path as correct as possible, but the "
+                    "skip itself is still stale for this title's per-frame same-address glyph "
+                    "rasterization, so OFF (force re-upload) is the reliable cure (verified clean by "
+                    "running; the GPU-written coherency risk did not manifest — a full match + "
+                    "results render correctly).")
     .lifecycle(rex::cvar::Lifecycle::kHotReload);
 
 REXCVAR_DEFINE_BOOL(occlusion_query_enable, true, "GPU", "Enable host occlusion query handling")
@@ -406,6 +416,17 @@ void CommandProcessor::UpdateWritePointer(uint32_t value) {
   write_ptr_index_event_->Set();
 }
 
+void CommandProcessor::RefreshVblankFence() {
+  // [recomp fix] Called on each vblank: push the live GPU vblank counter to the last
+  // EVENT_WRITE_SHD counter-fence the guest polls, so the guest sees vblank progress BETWEEN
+  // packets and its post-frame fence wait completes (boot intro -> title). No-op until a counter
+  // fence has been registered. Surfaces the real counter_, does not fake GPU completion.
+  if (vblank_fence_addr_) {
+    memory::store(memory_->TranslatePhysical(vblank_fence_addr_),
+                  GpuSwap(counter_, vblank_fence_endian_));
+  }
+}
+
 uint32_t CommandProcessor::ReadRegisterValue(uint32_t index) const {
   if (index < RegisterFile::kRegisterCount) {
     return register_file_->values[index];
@@ -429,8 +450,17 @@ void CommandProcessor::WriteRegister(uint32_t index, uint32_t value) {
 
   // Volatile for the WAIT_REG_MEM loop.
   const_cast<volatile uint32_t&>(regs.values[index]) = value;
-  if (!regs.GetRegisterInfo(index)) {
-    REXGPU_DEBUG("GPU: Write to unknown register ({:04X} = {:08X})", index, value);
+  // [perf] GetRegisterInfo() is a ~200-case switch evaluated on EVERY register
+  // write; its sole consumer is the debug log below, which is off in normal play
+  // (info level). Profiling showed it at ~4.5% of all CPU samples on the GPU
+  // command-processor thread -- a per-frame co-bottleneck under combat load.
+  // Gate the lookup on the log level so the hot path skips it entirely; behavior
+  // is unchanged when gpu debug logging is enabled.
+  if (auto* gpu_log = ::rex::GetLoggerRaw(::rex::log::gpu());
+      gpu_log && gpu_log->should_log(spdlog::level::debug)) {
+    if (!regs.GetRegisterInfo(index)) {
+      REXGPU_DEBUG("GPU: Write to unknown register ({:04X} = {:08X})", index, value);
+    }
   }
 
   // Scratch register writeback.
@@ -721,6 +751,17 @@ uint32_t CommandProcessor::ExecutePrimaryBuffer(uint32_t read_index, uint32_t wr
       assert_always();
       break;
     }
+    // [recomp fix] Periodic ring read-pointer write-back (the upstream TODO above). Publish the
+    // CP's CURRENT ring position to the guest's read-back pointer DURING the batch, not only after
+    // ExecutePrimaryBuffer returns. Without this, a guest that polls the read-back pointer mid-batch
+    // (the post-frame GPU-fence wait sub_821BFF48->sub_821C6E58 on 0xFFC9B000) cannot see the CP's
+    // progress and deadlocks against the CP still executing this batch -> the boot intro freezes
+    // after the first presented frame. This keeps rendering correct (it only surfaces real progress).
+    if (read_ptr_writeback_ptr_) {
+      memory::store_and_swap<uint32_t>(
+          memory_->TranslatePhysical(read_ptr_writeback_ptr_),
+          static_cast<uint32_t>(reader.read_offset() / sizeof(uint32_t)));
+    }
   } while (reader.read_count());
 
   OnPrimaryBufferEnd();
@@ -1068,6 +1109,51 @@ bool CommandProcessor::ExecutePacketType3_XE_SWAP(memory::RingBuffer* reader, ui
                                                   uint32_t count) {
   SCOPE_profile_cpu_f("gpu");
 
+  // Frame limiter (vsync on). This title paces its main loop on present/GPU
+  // progress; with the uncapped IMMEDIATE present the sim runs at render speed and
+  // wobbles with GPU load. Pace the CP's swap cadence to the guest refresh -- but
+  // ONLY during steady gameplay: skip while shaders are compiling (level load),
+  // because throttling the loading screen starves shader compilation and breaks
+  // the load. Plain sleep, never blocks on present (no deadlock).
+  if (REXCVAR_GET(vsync)) {
+    uint64_t freq = rex::chrono::Clock::QueryHostTickFrequency();
+    uint64_t now = rex::chrono::Clock::QueryHostTickCount();
+    bool loading = (now - LastPipelineHostTick().load(std::memory_order_relaxed)) < freq * 2;
+    static uint64_t next_swap = 0;
+    if (loading) {
+      next_swap = 0;  // not gameplay -> disarm; resync when throttling resumes
+    } else {
+      static double hz = 0.0;
+      if (hz <= 0.0) {
+        hz = REXCVAR_QUERY(double, video_mode_refresh_rate);
+        if (hz < 1.0) hz = 60.0;
+      }
+      uint64_t period = std::max<uint64_t>(1, uint64_t(double(freq) / hz));
+      if (next_swap == 0 || now > next_swap + period * 4) {
+        next_swap = now + period;  // (re)sync
+      } else if (now < next_swap) {
+        rex::thread::Sleep(std::chrono::microseconds((next_swap - now) * 1000000ull / freq));
+        next_swap += period;
+      } else {
+        next_swap += period;  // slightly behind: advance one step, no burst
+      }
+    }
+  }
+  {  // [pacing-diag] TEMP
+    static uint64_t d = 0, t0 = 0;
+    uint64_t nf = rex::chrono::Clock::QueryHostTickFrequency();
+    uint64_t nn = rex::chrono::Clock::QueryHostTickCount();
+    if (t0 == 0) t0 = nn;
+    ++d;
+    if (nn - t0 >= nf * 2) {
+      bool ld = (nn - LastPipelineHostTick().load(std::memory_order_relaxed)) < nf * 2;
+      REXGPU_INFO("[pacing-diag] swaps {:.1f}/s loading={}", double(d) * double(nf) / double(nn - t0),
+                  ld);
+      d = 0;
+      t0 = nn;
+    }
+  }
+
 #ifdef REXGLUE_ENABLE_PERF_COUNTERS
   {
     static uint64_t last_frame_tick = 0;
@@ -1128,6 +1214,7 @@ bool CommandProcessor::ExecutePacketType3_WAIT_REG_MEM(memory::RingBuffer* reade
   bool is_memory = (wait_info & 0x10) != 0;
 
   bool matched = false;
+  uint32_t spin_count = 0;  // [diag] detect a WAIT_REG_MEM that never satisfies
   do {
     uint32_t value = 0;
     if (is_memory) {
@@ -1169,21 +1256,56 @@ bool CommandProcessor::ExecutePacketType3_WAIT_REG_MEM(memory::RingBuffer* reade
         break;
     }
     if (!matched) {
+      // [diag] Surface a stuck WAIT_REG_MEM: log poll target + live value once it
+      // has clearly failed to satisfy, then periodically to see if it ever moves.
+      // Only log fences that exceed the fast-poll budget (genuinely slow); fences resolving within
+      // it are normal and were spamming the log (heavy I/O that throttled the CP).
+      if (spin_count == 12000 || (spin_count > 12000 && (spin_count % 100000) == 0)) {
+        REXGPU_WARN(
+            "WAIT_REG_MEM stuck: is_mem={} poll=0x{:08X} func=0x{:X} ref=0x{:08X} "
+            "mask=0x{:08X} value=0x{:08X} wait=0x{:X} spins={}",
+            is_memory, poll_reg_addr, wait_info & 0x7, ref, mask, value, wait, spin_count);
+      }
+      ++spin_count;
+      // [recomp stop-gap] A WAIT_REG_MEM has no PM4 timeout: if the gated guest fence never
+      // resolves it hangs the command processor forever (observed in the boot present/vsync +
+      // fence deadlock). After a large spin budget, proceed anyway -- in the stuck cases the GPU
+      // work it gates is already complete. Verify post-reboot; the real fix is runtime GPU-fence
+      // write-back. See knowledge-base/titles/south-park-lgtdp/60-boot-present-deadlock.md.
+      if (spin_count > 500000u) {
+        REXGPU_WARN(
+            "WAIT_REG_MEM escape: proceeding after {} spins (poll=0x{:08X} func=0x{:X} "
+            "ref=0x{:08X} mask=0x{:08X})",
+            spin_count, poll_reg_addr, wait_info & 0x7, ref, mask);
+        break;
+      }
       // Wait.
       if (wait >= 0x100) {
-        PrepareForWait();
-        if (!REXCVAR_GET(vsync)) {
-          // User wants it fast and dangerous.
+        // [recomp fix] Fast-poll (memory sync + yield, NO 1 ms sleep) for a short budget before
+        // falling back to sleeping. The original slept ~1 ms on every unmatched poll, so a fence
+        // that takes many polls to resolve makes the CP crawl and fall far behind the guest's frame
+        // pacing -> the guest's post-frame fence wait never sees the CP catch up (the boot intro
+        // freeze after the first presented frame). MaybeYield lets the guest thread run to write the
+        // fence and lets the CP be rescheduled immediately, so fast fences resolve in microseconds
+        // and the CP keeps step. Same waits, just not throttled -> rendering stays correct.
+        if (spin_count < 8000u) {
+          rex::thread::SyncMemory();
           rex::thread::MaybeYield();
         } else {
-          rex::thread::Sleep(std::chrono::milliseconds(wait / 0x100));
-        }
-        rex::thread::SyncMemory();
-        ReturnFromWait();
+          PrepareForWait();
+          if (!REXCVAR_GET(vsync)) {
+            // User wants it fast and dangerous.
+            rex::thread::MaybeYield();
+          } else {
+            rex::thread::Sleep(std::chrono::milliseconds(wait / 0x100));
+          }
+          rex::thread::SyncMemory();
+          ReturnFromWait();
 
-        if (!worker_running_) {
-          // Short-circuited exit.
-          return false;
+          if (!worker_running_) {
+            // Short-circuited exit.
+            return false;
+          }
         }
       } else {
         rex::thread::MaybeYield();
@@ -1347,7 +1469,8 @@ bool CommandProcessor::ExecutePacketType3_EVENT_WRITE_SHD(memory::RingBuffer* re
   // Writeback initiator.
   WriteRegister(XE_GPU_REG_VGT_EVENT_INITIATOR, initiator & 0x3F);
   uint32_t data_value;
-  if ((initiator >> 31) & 0x1) {
+  bool is_counter = ((initiator >> 31) & 0x1) != 0;
+  if (is_counter) {
     // Write counter (GPU vblank counter?).
     data_value = counter_;
   } else {
@@ -1356,6 +1479,15 @@ bool CommandProcessor::ExecutePacketType3_EVENT_WRITE_SHD(memory::RingBuffer* re
   }
   auto endianness = static_cast<xenos::Endian>(address & 0x3);
   address &= ~0x3;
+  // [recomp fix] Remember this GPU-vblank-counter fence so MarkVblank can keep refreshing it with
+  // the live counter_ between EVENT_WRITE_SHD packets. Otherwise a guest that polls this fence for
+  // the vblank counter to reach a target only ever sees the value written here at packet time and
+  // never the vblank ticks in between -> it deadlocks (the boot intro freezes after frame 1). This
+  // surfaces the REAL counter on each vblank; it does not fake GPU completion.
+  if (is_counter) {
+    vblank_fence_addr_ = address;
+    vblank_fence_endian_ = endianness;
+  }
   data_value = GpuSwap(data_value, endianness);
   memory::store(memory_->TranslatePhysical(address), data_value);
   trace_writer_.WriteMemoryWrite(CpuToGpu(address), 4);
diff --git a/src/graphics/graphics_system.cpp b/src/graphics/graphics_system.cpp
index 3877b1a..b147398 100644
--- a/src/graphics/graphics_system.cpp
+++ b/src/graphics/graphics_system.cpp
@@ -332,6 +332,10 @@ void GraphicsSystem::MarkVblank() {
   // Increment vblank counter (so the game sees us making progress).
   if (command_processor_) {
     command_processor_->increment_counter();
+    // [recomp fix] Also publish the live counter to the guest's GPU-vblank-counter fence so a guest
+    // polling it between EVENT_WRITE_SHD packets sees vblank progress (fixes the boot intro freeze
+    // where the guest waits forever for the counter target the fence was never refreshed to).
+    command_processor_->RefreshVblankFence();
   }
 
   // TODO(benvanik): we shouldn't need to do the dispatch here, but there's
