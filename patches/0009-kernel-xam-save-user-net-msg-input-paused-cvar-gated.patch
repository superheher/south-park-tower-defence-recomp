+namespace {
+
+// XSESSION create flags (subset). HOST distinguishes the host from a joiner;
+// the *_USES_* bits mark an Xbox Live (vs pure system-link/local) session.
+enum {
+  XSESSION_CREATE_HOST = 0x00000001,
+  XSESSION_CREATE_USES_PRESENCE = 0x00000002,
+  XSESSION_CREATE_USES_STATS = 0x00000004,
+  XSESSION_CREATE_USES_MATCHMAKING = 0x00000008,
+  XSESSION_CREATE_USES_ARBITRATION = 0x00000010,
+  XSESSION_CREATE_USES_PEER_NETWORK = 0x00000020,
+};
+
+// Process-global netplay session bookkeeping (one active session per instance).
+struct NpSession {
+  bool active = false;
+  bool is_host = false;
+  std::string session_id_hex;     // current session XNKID (hex)
+  std::string pending_search_id;  // last session id returned by Search (for join)
+  uint8_t host_xnaddr[36] = {};   // host XNADDR (set on host create / search hit)
+  uint8_t session_key[16] = {};   // XNKEY
+};
+NpSession g_np;
+
+std::string BytesToHex(const uint8_t* p, size_t n) {
+  static const char* d = "0123456789abcdef";
+  std::string s;
+  s.resize(n * 2);
+  for (size_t i = 0; i < n; ++i) {
+    s[i * 2] = d[p[i] >> 4];
+    s[i * 2 + 1] = d[p[i] & 0xF];
+  }
+  return s;
+}
+
+// Generate a unique 8-byte XNKID for a host session. High bit of byte 0 marks
+// an "online" session id (matches the platform convention closely enough).
+void GenXnkid(uint8_t out[8], int instance) {
+  uint64_t t = (uint64_t)std::chrono::steady_clock::now().time_since_epoch().count();
+  static std::atomic<uint32_t> seq{0};
+  uint32_t s = ++seq;
+  out[0] = 0xAE;  // online session marker
+  out[1] = (uint8_t)instance;
+  out[2] = (uint8_t)(s & 0xFF);
+  out[3] = (uint8_t)((s >> 8) & 0xFF);
+  out[4] = (uint8_t)(t & 0xFF);
+  out[5] = (uint8_t)((t >> 8) & 0xFF);
+  out[6] = (uint8_t)((t >> 16) & 0xFF);
+  out[7] = (uint8_t)((t >> 24) & 0xFF);
+}
+
+// Hex dump a guest buffer to the log (recon aid for unimplemented messages).
+void LogBuffer(const char* what, uint8_t* buffer, uint32_t len) {
+  if (!buffer || !len || len > 256) {
+    REXKRNL_DEBUG("[netplay] {} buffer_len={}", what, len);
+    return;
+  }
+  REXKRNL_DEBUG("[netplay] {} ({}B): {}", what, len, BytesToHex(buffer, len));
+}
+
+}  // namespace
+
 XgiApp::XgiApp(KernelState* kernel_state) : App(kernel_state, 0xFB) {}
 
