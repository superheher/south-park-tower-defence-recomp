@@ -29,6 +98,82 @@ X_HRESULT XgiApp::DispatchMessageSync(uint32_t message, uint32_t buffer_ptr,
                                       uint32_t buffer_length) {
   // NOTE: buffer_length may be zero or valid.
   auto buffer = memory_->TranslateVirtual(buffer_ptr);
+  // [netplay] Recon: log every XGI message + buffer when online co-op is active.
+  if (Netplay::Get().enabled()) {
+    REXKRNL_INFO("[netplay] XGI msg={:08X} len={}", message, buffer_length);
+    LogBuffer("XGI", buffer, buffer_length);
+  }
+
+  // [netplay] Fill an XSESSION_SEARCHRESULT buffer from the broker. Writes the
+  // XSESSIONSEARCHRESULT_HEADER {dwSearchResults, pResults} followed by an array
+  // of XSESSION_SEARCHRESULT (XSESSION_INFO[60] + 6 DWORD slot/count fields + 2
+  // ptrs = 0x5C each). Returns the number of sessions written.
+  auto fill_search = [this](uint32_t results_ptr, uint32_t buf_size,
+                            uint32_t max_results) -> uint32_t {
+    auto& np = Netplay::Get();
+    std::vector<Netplay::SessionResult> results;
+    np.Search(7, results);
+    if (max_results && results.size() > max_results) results.resize(max_results);
+    const uint32_t kHeader = 8;
+    const uint32_t kResultSz = 0x5C;  // 92
+    uint32_t count = (uint32_t)results.size();
+    uint32_t needed = kHeader + count * kResultSz;
+    if (buf_size && buf_size < needed) {
+      REXKRNL_WARN("[netplay] search buf too small: have {} need {} ({} results)",
+                   buf_size, needed, count);
+      while (count && kHeader + count * kResultSz > buf_size) count--;
+    }
+    if (!results_ptr) return count;
+    uint8_t* base = memory_->TranslateVirtual(results_ptr);
+    uint32_t array_addr = results_ptr + kHeader;
+    memory::store_and_swap<uint32_t>(base + 0, count);
+    memory::store_and_swap<uint32_t>(base + 4, count ? array_addr : 0);
+    for (uint32_t i = 0; i < count; ++i) {
+      auto& r = results[i];
+      uint8_t* e = base + kHeader + i * kResultSz;
+      // XSESSION_INFO.hostAddress (36-byte XNADDR)
+      uint8_t xn[36];
+      if (r.host_xnaddr.size() == 36) {
+        std::memcpy(xn, r.host_xnaddr.data(), 36);
+      } else {
+        // Reconstruct from key + ip if the host didn't publish a full XNADDR.
+        std::memset(xn, 0, 36);
+        std::memcpy(xn + 0, &r.host_ip_net, 4);
+        std::memcpy(xn + 4, &r.host_ip_net, 4);
+        xn[8] = (uint8_t)(r.host_port >> 8);    // wPortOnline, network order
+        xn[9] = (uint8_t)(r.host_port & 0xFF);
+        for (size_t b = 0; b + 1 < r.host_online_key_hex.size() && b / 2 < 20; b += 2)
+          xn[16 + b / 2] =
+              (uint8_t)std::stoul(r.host_online_key_hex.substr(b, 2), nullptr, 16);
+      }
+      // XSESSION_INFO layout: sessionID(XNKID,8)@0, hostAddress(XNADDR,36)@8,
+      // keyExchangeKey(XNKEY,16)@44. The session id MUST come first (the title
+      // checks sessionID.ab[0]==0xAE to accept it as an online session).
+      for (int b = 0; b < 8 && (size_t)(b * 2 + 1) < r.session_id_hex.size(); ++b)
+        e[0 + b] = (uint8_t)std::stoul(r.session_id_hex.substr(b * 2, 2), nullptr, 16);
+      std::memcpy(e + 8, xn, 36);       // hostAddress (XNADDR)
+      std::memset(e + 44, 0xA5, 16);    // keyExchangeKey (XNKEY)
+      // open/filled slot counts + property/context counts (none)
+      memory::store_and_swap<uint32_t>(e + 60, r.open_pub);
+      memory::store_and_swap<uint32_t>(e + 64, r.open_priv);
+      memory::store_and_swap<uint32_t>(e + 68, 1);
+      memory::store_and_swap<uint32_t>(e + 72, 0);
+      memory::store_and_swap<uint32_t>(e + 76, 0);
+      memory::store_and_swap<uint32_t>(e + 80, 0);
+      memory::store_and_swap<uint32_t>(e + 84, 0);
+      memory::store_and_swap<uint32_t>(e + 88, 0);
+    }
+    if (count) {
+      g_np.pending_search_id = results[0].session_id_hex;
+      std::memset(g_np.session_key, 0xA5, sizeof(g_np.session_key));
+      if (results[0].host_xnaddr.size() == 36)
+        std::memcpy(g_np.host_xnaddr, results[0].host_xnaddr.data(), 36);
+    }
+    REXKRNL_INFO("[netplay] search wrote {} result(s) to {:08X}", count, results_ptr);
+    return count;
+  };
+  (void)fill_search;
+
   switch (message) {
     case 0x000B0006: {
       assert_true(!buffer_length || buffer_length == 24);
@@ -81,6 +226,78 @@ X_HRESULT XgiApp::DispatchMessageSync(uint32_t message, uint32_t buffer_ptr,
           "{:08X})",
           session_ptr, flags, num_slots_public, num_slots_private, user_xuid, session_info_ptr,
