+            "info_ptr={:08X} nonce_ptr={:08X} host={}",
+            flags, num_slots_public, num_slots_private, user_xuid, session_info_ptr, nonce_ptr,
+            (flags & XSESSION_CREATE_HOST) ? 1 : 0);
