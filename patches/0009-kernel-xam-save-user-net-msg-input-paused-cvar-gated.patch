+          std::memcpy(info + 0, xnkid, 8);                 // sessionID (XNKID)
+          std::memcpy(info + 8, g_np.host_xnaddr, 36);     // hostAddress (XNADDR)
+          std::memcpy(info + 44, g_np.session_key, 16);    // keyExchangeKey (XNKEY)
+
+          // The host session nonce is an OUTPUT of XSessionCreate — generate a
+          // non-zero one (the title carries it into Start/Arbitration/Delete).
+          if (nonce_ptr) {
+            uint64_t nonce =
+                ((uint64_t)std::chrono::steady_clock::now().time_since_epoch().count() << 16) ^
+                0x9E3779B97F4A7C15ull ^ ((uint64_t)(np.instance() + 1) * 0x100000001B3ull);
+            if (!nonce) nonce = 0x5350000000000001ull;
+            memory::store_and_swap<uint64_t>(memory_->TranslateVirtual(nonce_ptr), nonce);
+          }
+
+          g_np.active = true;
+          g_np.is_host = true;
+          g_np.session_id_hex = sid;
+          np.CreateSession(sid, flags, num_slots_public, num_slots_private, 7);
+          REXKRNL_INFO("[netplay] HOST session {} created (pub={}, priv={}); XSESSION_INFO={}", sid,
+                       num_slots_public, num_slots_private, BytesToHex(info, 60));
+        } else if (!g_np.pending_search_id.empty()) {
+          // Joining: a prior Search found a host. Write the host's XNKID/XNADDR
+          // into our local session info and register the join with the broker.
+          std::string sid = g_np.pending_search_id;
