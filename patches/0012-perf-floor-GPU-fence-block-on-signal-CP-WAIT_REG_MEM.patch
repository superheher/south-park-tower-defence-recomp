--- a/src/graphics/graphics_system.cpp
+++ b/src/graphics/graphics_system.cpp
@@ -337,6 +337,11 @@ void GraphicsSystem::MarkVblank() {
     // where the guest waits forever for the counter target the fence was never refreshed to).
     command_processor_->RefreshVblankFence();
   }
+  // [recomp fix: block-on-signal] Wake any guest thread parked in REX_SPIN_BACKOFF's
