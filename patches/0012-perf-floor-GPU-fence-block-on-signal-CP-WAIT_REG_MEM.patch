diff --git a/include/rex/graphics/command_processor.h b/include/rex/graphics/command_processor.h
index af1546f..4951cd3 100644
--- a/include/rex/graphics/command_processor.h
+++ b/include/rex/graphics/command_processor.h
@@ -12,6 +12,7 @@
 #pragma once
 
 #include <atomic>
+#include <condition_variable>
 #include <cstring>
 #include <functional>
 #include <memory>
@@ -285,6 +286,13 @@ class CommandProcessor {
   // [recomp fix] Last EVENT_WRITE_SHD GPU-vblank-counter fence target, refreshed each vblank.
   uint32_t vblank_fence_addr_ = 0;
   xenos::Endian vblank_fence_endian_ = xenos::Endian::kNone;
+  // [recomp fix: block-on-signal] When the CP's WAIT_REG_MEM polls the GPU vblank-counter fence
+  // (vblank_fence_addr_), the value is advanced ONLY by the vsync thread (RefreshVblankFence, 60 Hz)
+  // while the CP is parked here -- so the CP can block on this CV instead of spin-polling it. The
+  // vsync thread notify_all()s it the instant it advances counter_, so the CP wakes promptly at
+  // ~zero CPU. This is the "runtime GPU-fence write-back" the WAIT_REG_MEM comment asks for.
+  std::mutex vblank_fence_mutex_;
+  std::condition_variable vblank_fence_cv_;
 
   uint32_t primary_buffer_ptr_ = 0;
   uint32_t primary_buffer_size_ = 0;
diff --git a/include/rex/thread.h b/include/rex/thread.h
index 30b207d..9bf4843 100644
--- a/include/rex/thread.h
+++ b/include/rex/thread.h
@@ -111,6 +111,14 @@ void MaybeYield();
 // Memory barrier (request - may be ignored).
 void SyncMemory();
 
+// [recomp fix: block-on-signal] Park the current thread until the next guest vblank (or a short
+// timeout), for use as the long-spin backoff in recompiled guest spin-waits (REX_SPIN_BACKOFF): a
+// guest thread waiting on a GPU/vblank fence (which only advances on a vblank) frees its core instead
+// of pause-spinning. NotifyVblank() is called by the GPU vsync thread (MarkVblank) each vblank to wake
+// parked waiters. The waiter re-checks its guest condition on return, so this changes no guest result.
+void VblankBackoffWait();
+void NotifyVblank();
+
 // Sleeps the current thread for at least as long as the given duration.
 void Sleep(std::chrono::microseconds duration);
 template <typename Rep, typename Period>
diff --git a/resources/templates/codegen/init_h.inja b/resources/templates/codegen/init_h.inja
index 40f395e..64ad409 100644
--- a/resources/templates/codegen/init_h.inja
+++ b/resources/templates/codegen/init_h.inja
@@ -39,12 +39,14 @@
 #include <rex/logging.h>
 #include <rex/chrono/clock.h>
 #include <rex/perf/counter.h>
+#include <rex/thread.h>
 #include <rex/thread/mutex.h>
 #include <rex/system/mmio_handler.h>
 #include <rex/platform/exceptions.h>  // SEH_TRY/SEH_CATCH_ALL for generate_exception_handlers
 
 #include <atomic>
 #include <cassert>
+#include <chrono>
 #include <csetjmp>
 #include <cstdlib>
 #include <stdexcept>
@@ -67,8 +69,23 @@ static inline void rex_spin_backoff() noexcept {
 #if (defined(__x86_64__) || defined(__i386__)) && (defined(__GNUC__) || defined(__clang__))
   __builtin_ia32_pause();
 #endif
+  // After a long spin (the thread has clearly been parked on a cross-thread / GPU condition -- e.g.
+  // the guest Main thread's post-frame GPU vblank-fence wait, which otherwise pegs a host core at
+  // ~5.3 G insn/s), PARK BRIEFLY instead of just yielding. std::this_thread::yield() does NOT
+  // deschedule the thread when it is the only runnable one on its core, so the spinner keeps stealing
+  // CPU from the very threads (CP / render / sim) that will satisfy the wait. A short sleep frees the
+  // core; the guest loop re-checks the same condition on return, so there is NO guest-visible change
+  // -- only the busy-wait stops hogging the core. Short guest locks resolve far below this threshold
+  // (they only ever hit the PAUSE), so they keep their microsecond latency. See FLOOR-OVEREXEC report.
   static thread_local unsigned rex_sb_ctr = 0;
-  if ((++rex_sb_ctr & 0x3FFFu) == 0u) std::this_thread::yield();
+  if ((++rex_sb_ctr & 0x0FFFu) == 0u) {
+    // Park until the next guest vblank (or a 2 ms timeout) instead of just yielding/pausing. A
+    // GPU/vblank fence the guest spins on only advances on a vblank, so parking here frees the host
+    // core for the full inter-vblank gap (vs pause-spinning ~34% of all combat-dip cycles in the
+    // fence predicate) and the guest loop re-checks the same condition on wake -- no guest-visible
+    // change. Short guest locks resolve far below this threshold (they only hit the PAUSE above).
+    rex::thread::VblankBackoffWait();
+  }
 }
 #define REX_SPIN_BACKOFF() rex_spin_backoff()
 
diff --git a/src/core/threading_posix.cpp b/src/core/threading_posix.cpp
index e10e30b..47e346b 100644
--- a/src/core/threading_posix.cpp
+++ b/src/core/threading_posix.cpp
@@ -16,9 +16,11 @@ static_assert(REX_PLATFORM_LINUX || REX_PLATFORM_MAC, "This file is POSIX-only")
 #include <atomic>
 #include <array>
 #include <cerrno>
+#include <condition_variable>
 #include <cstddef>
 #include <ctime>
 #include <deque>
+#include <mutex>
 #include <limits>
 #include <memory>
 
@@ -157,6 +159,26 @@ void SyncMemory() {
   __sync_synchronize();
 }
 
+// [recomp fix: block-on-signal] Global guest-vblank parking signal. A recompiled guest spin-wait on a
+// GPU/vblank fence (the value only advances on a vblank) calls VblankBackoffWait() once it has clearly
+// been spinning a while (REX_SPIN_BACKOFF threshold), parking the thread until the GPU vsync thread's
+// next MarkVblank() -> NotifyVblank(), instead of pause-spinning a host core (measured: the Main
+// thread otherwise burns ~34% of all combat-dip cycles in the fence predicate). The waiter re-checks
+// its guest condition on return, and the 2 ms timeout bounds any lost wakeup, so this can never
+// deadlock and changes no guest-visible result -- it only stops the busy-wait from stealing CPU from
+// the CP/render/sim threads that actually advance the frame.
+namespace {
+std::mutex g_vblank_backoff_mutex;
+std::condition_variable g_vblank_backoff_cv;
+}  // namespace
+
+void VblankBackoffWait() {
+  std::unique_lock<std::mutex> lk(g_vblank_backoff_mutex);
+  g_vblank_backoff_cv.wait_for(lk, std::chrono::milliseconds(2));
+}
+
+void NotifyVblank() { g_vblank_backoff_cv.notify_all(); }
+
 void Sleep(std::chrono::microseconds duration) {
   timespec rqtp = DurationToTimeSpec(duration);
   timespec rmtp = {};
diff --git a/src/graphics/command_processor.cpp b/src/graphics/command_processor.cpp
index 7ed8470..fae013e 100644
--- a/src/graphics/command_processor.cpp
+++ b/src/graphics/command_processor.cpp
@@ -424,6 +424,12 @@ void CommandProcessor::RefreshVblankFence() {
   if (vblank_fence_addr_) {
     memory::store(memory_->TranslatePhysical(vblank_fence_addr_),
                   GpuSwap(counter_, vblank_fence_endian_));
+    // [recomp fix: block-on-signal] Wake the CP if it is parked in WAIT_REG_MEM on this fence.
+    // We just advanced the value it is waiting for; notify it so it re-checks immediately instead
+    // of burning a core spin-polling (the ~17%-CP-cycles sched_yield wall in a heavy combat dip).
+    // notify_all without holding vblank_fence_mutex_ is fine: the waiter uses a bounded timeout and
+    // re-reads the value in its loop, so a lost wakeup can only delay it by that timeout, never hang.
+    vblank_fence_cv_.notify_all();
   }
 }
 
@@ -456,8 +462,11 @@ void CommandProcessor::WriteRegister(uint32_t index, uint32_t value) {
   // command-processor thread -- a per-frame co-bottleneck under combat load.
   // Gate the lookup on the log level so the hot path skips it entirely; behavior
   // is unchanged when gpu debug logging is enabled.
-  if (auto* gpu_log = ::rex::GetLoggerRaw(::rex::log::gpu());
-      gpu_log && gpu_log->should_log(spdlog::level::debug)) {
+  // [perf] Cache the logger pointer: GetLoggerRaw() itself was ~3% of all CP cycles during a combat
+  // dip (called on EVERY register write just to test the debug level). The logger object is stable
+  // for the process, so look it up once; should_log() is a cheap atomic load. Behavior unchanged.
+  static auto* const gpu_log = ::rex::GetLoggerRaw(::rex::log::gpu());
+  if (gpu_log && gpu_log->should_log(spdlog::level::debug)) {
     if (!regs.GetRegisterInfo(index)) {
       REXGPU_DEBUG("GPU: Write to unknown register ({:04X} = {:08X})", index, value);
     }
@@ -1215,6 +1224,9 @@ bool CommandProcessor::ExecutePacketType3_WAIT_REG_MEM(memory::RingBuffer* reade
 
   bool matched = false;
   uint32_t spin_count = 0;  // [diag] detect a WAIT_REG_MEM that never satisfies
+  // [recomp fix: block-on-signal] Wall-clock start of CP-vblank-fence blocking, for a deadlock
+  // backstop independent of the CV timeout granularity (0 = not yet blocking on the fence CV).
+  uint64_t cv_block_start_tick = 0;
   do {
     uint32_t value = 0;
     if (is_memory) {
@@ -1272,41 +1284,65 @@ bool CommandProcessor::ExecutePacketType3_WAIT_REG_MEM(memory::RingBuffer* reade
       // fence deadlock). After a large spin budget, proceed anyway -- in the stuck cases the GPU
       // work it gates is already complete. Verify post-reboot; the real fix is runtime GPU-fence
       // write-back. See knowledge-base/titles/south-park-lgtdp/60-boot-present-deadlock.md.
-      if (spin_count > 500000u) {
+      // [recomp fix: block-on-signal] The CV-blocking path below sleeps up to a few ms per spin, so
+      // the spin_count==500k backstop (≈1 s of fast-poll) would take many minutes to trip. Add a
+      // wall-clock deadline so a fence that genuinely never resolves still escapes in ≈1 s, matching
+      // the fast-poll backstop. counter_ is advanced every vblank, so a vblank-fence wait virtually
+      // always resolves; this only guards the pathological hang.
+      bool cv_escape = cv_block_start_tick != 0 &&
+                       (rex::chrono::Clock::QueryHostTickCount() - cv_block_start_tick) >
+                           rex::chrono::Clock::QueryHostTickFrequency();
+      if (spin_count > 500000u || cv_escape) {
         REXGPU_WARN(
             "WAIT_REG_MEM escape: proceeding after {} spins (poll=0x{:08X} func=0x{:X} "
             "ref=0x{:08X} mask=0x{:08X})",
             spin_count, poll_reg_addr, wait_info & 0x7, ref, mask);
         break;
       }
-      // Wait.
-      if (wait >= 0x100) {
-        // [recomp fix] Fast-poll (memory sync + yield, NO 1 ms sleep) for a short budget before
-        // falling back to sleeping. The original slept ~1 ms on every unmatched poll, so a fence
-        // that takes many polls to resolve makes the CP crawl and fall far behind the guest's frame
-        // pacing -> the guest's post-frame fence wait never sees the CP catch up (the boot intro
-        // freeze after the first presented frame). MaybeYield lets the guest thread run to write the
-        // fence and lets the CP be rescheduled immediately, so fast fences resolve in microseconds
-        // and the CP keeps step. Same waits, just not throttled -> rendering stays correct.
-        if (spin_count < 8000u) {
+      // [recomp fix: block-on-signal -- the "runtime GPU-fence write-back" the WAIT_REG_MEM comment
+      // asks for] In a heavy combat dip the CP pegs a core spin-polling this fence (~37% of cycles,
+      // ~17% of them in the sched_yield of the old fast-poll) while the guest sim/render threads
+      // starve -> the frame quantizes to 60/N. The awaited fences resolve only at vblank cadence:
+      // the vblank-counter fence is advanced by the vsync thread (RefreshVblankFence, 60 Hz), and
+      // the EOP "cleared-to-0" fence (the combat poll 0x..C9B004, func=equal ref=0) is cleared by
+      // the guest *after* the vsync tick wakes its own frame loop. So a CP parked here can only make
+      // progress on a vsync tick. Therefore: after a brief pure-pause poll (catch sub-~100us fences
+      // with no syscall and no core release), BLOCK on the fence CV. RefreshVblankFence
+      // notify_all()s it every vsync tick and a short timeout re-reads the value (the do-while), so
+      // a parked CP wakes at ~zero CPU within a vsync (or the 1 ms timeout), never deadlocks
+      // (counter_ always advances; worker_running_ and the wall-clock escape are backstops), and the
+      // freed core goes to the guest's real work -> lifts the floor. Replaces the old 8000x
+      // sched_yield fast-poll (the kernel wall) + 1 ms Sleep fallback.
+      if (REXCVAR_GET(vsync) && wait >= 0x100) {
+        if (spin_count < 512u) {
+          // Brief tight poll: pure x86 PAUSE, NO sched_yield syscall -> genuinely-fast fences still
+          // resolve in microseconds without parking, and this alone removes the ~17% kernel wall.
           rex::thread::SyncMemory();
+#if (defined(__x86_64__) || defined(__i386__)) && (defined(__GNUC__) || defined(__clang__))
+          __builtin_ia32_pause();
+#else
           rex::thread::MaybeYield();
+#endif
         } else {
+          if (cv_block_start_tick == 0) {
+            cv_block_start_tick = rex::chrono::Clock::QueryHostTickCount();
+          }
           PrepareForWait();
-          if (!REXCVAR_GET(vsync)) {
-            // User wants it fast and dangerous.
-            rex::thread::MaybeYield();
-          } else {
-            rex::thread::Sleep(std::chrono::milliseconds(wait / 0x100));
+          {
+            std::unique_lock<std::mutex> lk(vblank_fence_mutex_);
+            vblank_fence_cv_.wait_for(lk, std::chrono::milliseconds(1));
           }
           rex::thread::SyncMemory();
           ReturnFromWait();
-
           if (!worker_running_) {
             // Short-circuited exit.
             return false;
           }
         }
+      } else if (wait >= 0x100) {
+        // vsync off: keep the original fast-and-dangerous tight poll (user opted out of pacing).
+        rex::thread::SyncMemory();
+        rex::thread::MaybeYield();
       } else {
         rex::thread::MaybeYield();
       }
diff --git a/src/graphics/graphics_system.cpp b/src/graphics/graphics_system.cpp
