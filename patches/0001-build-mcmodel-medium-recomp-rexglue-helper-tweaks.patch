From 8eda42354c16d9231f6e226e304ccc6cd41b7b17 Mon Sep 17 00:00:00 2001
From: superheher <heh@vivaldi.net>
Date: Sat, 30 May 2026 16:22:02 +0300
Subject: [PATCH 01/13] build: -mcmodel=medium recomp + rexglue helper tweaks


diff --git a/CMakeLists.txt b/CMakeLists.txt
index 83902e7..7e25a7e 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -89,8 +89,17 @@ set(CMAKE_RELWITHDEBINFO_POSTFIX rd)
 if(NOT WIN32)
     # Use appropriate code model based on architecture
     if(CMAKE_SYSTEM_PROCESSOR MATCHES "AMD64|x86_64")
-        # Large code model on x86_64 for linking with very large recompiled executables (35MB+)
-        add_compile_options(-mcmodel=large)
+        # -mcmodel=medium (not large) for all SDK libs (rexcore/graphics/audio/... OBJECT libs +
+        # the rexruntime SHARED lib = librexruntime.so). Same indirect-call pathology the recomp exe
+        # had under large: LARGE forces `movabs $imm64; call *reg`/`jmp *reg` for EVERY internal call,
+        # over-subscribing the ~4K-entry BTB -> a front-end resteer storm. The .so has ~142k indirect
+        # calls / ~221k movabs under large. MEDIUM lets intra-.so calls use 32-bit pc-relative direct
+        # branches (the .so is ~21MB << 2GB) while still 64-bit-addressing any >64KB data object, so it
+        # is safe. The .so is PIC, so cross-module calls still go via GOT/PLT, but the internal call
+        # graph (most of the 142k) becomes direct. The recomp exe is built in the PORT tree (find_package,
+        # not this directory) and already gets medium via rexglue_apply_target_settings.
+        # See docs/FLOOR-MCMODEL-MEDIUM-REPORT.md + FLOOR-SO-MEDIUM-REPORT.md.
+        add_compile_options(-mcmodel=medium)
     else()
         # Small code model for other architectures (ARM64, etc.)
         add_compile_options(-mcmodel=small)
diff --git a/cmake/rexglue_helpers.cmake b/cmake/rexglue_helpers.cmake
index 4bd6694..0bff908 100644
--- a/cmake/rexglue_helpers.cmake
+++ b/cmake/rexglue_helpers.cmake
@@ -19,10 +19,20 @@ function(rexglue_apply_target_settings target_name)
         pkg_check_modules(GTK3 REQUIRED gtk+-3.0)
         target_include_directories(${target_name} PRIVATE ${GTK3_INCLUDE_DIRS})
         target_link_libraries(${target_name} PRIVATE ${GTK3_LIBRARIES})
-        # Large executable support
+        # Large executable support.
+        # NOTE: -mcmodel=medium (not large) on x86_64. The recompiled .text is ~19MB
+        # (<<2GB), so intra-module calls fit a 32-bit pc-relative displacement. Under the
+        # LARGE model clang must materialize every callee address (movabs $imm64) and emit
+        # an INDIRECT `call *reg`/`jmp *reg`; with ~20k+ such sites the BTB (~4K entries)
+        # is hopelessly over-subscribed -> ~65% of guest calls mispredict their target
+        # (measured: br_misp_retired.near_call dominated the front-end resteer storm that
+        # gates the combat floor). MEDIUM keeps code in the low 2GB (direct `call rel32`,
+        # no target prediction needed) while still addressing any >64KB data object with a
+        # 64-bit absolute, so it is safe for the 4GB guest arena (which is mmap'd at runtime
+        # via a register base anyway, not a linked symbol). See docs/FLOOR-MCMODEL-*.md.
         if(CMAKE_SYSTEM_PROCESSOR MATCHES "x86_64|AMD64")
             target_link_options(${target_name} PRIVATE -Wl,--no-relax)
-            target_compile_options(${target_name} PRIVATE -mcmodel=large)
+            target_compile_options(${target_name} PRIVATE -mcmodel=medium)
         elseif(CMAKE_SYSTEM_PROCESSOR MATCHES "aarch64|ARM64")
             target_compile_options(${target_name} PRIVATE -march=armv8-a)
         endif()
