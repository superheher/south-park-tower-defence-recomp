diff --git a/src/system/thread_state.cpp b/src/system/thread_state.cpp
index eb352a0..fb94c06 100644
--- a/src/system/thread_state.cpp
+++ b/src/system/thread_state.cpp
@@ -35,8 +35,16 @@ ThreadState::ThreadState(uint32_t thread_id, uint32_t stack_base, uint32_t pcr_a
   // Initialize the PPCContext (context_ already points to context_storage_)
   std::memset(context_, 0, sizeof(::PPCContext));
 
-  // Set initial registers
-  context_->r1.u64 = stack_base;    // Stack pointer
+  // Set initial registers.
+  // stack_base is the exclusive top of the guest stack and sits on a
+  // PAGE_NOACCESS guard page (usable RW stack is below it). A guest entry thunk
+  // with no prologue may immediately read its caller (loader) frame *above* r1
+  // (e.g. South Park LGTDP's xstart: `addi r1,r1,112; lwz r12,-8(r1)` reads
+  // [r1+104]). Starting r1 exactly at stack_base makes those reads fault on the
+  // guard. Reserve a small, 16-byte-aligned initial frame below stack_base so
+  // the loader-frame reads land in committed RW stack. Harmless for normal
+  // threads (whose functions have prologues).
+  context_->r1.u64 = (stack_base - 0x100) & ~UINT32_C(0xF);  // Stack pointer
   context_->r13.u64 = pcr_address;  // PCR address
 
   // Note(tomc): the rexglue abi passes memory base via 'base' parameter to each function call,
