diff --git a/src/system/kernel_state.cpp b/src/system/kernel_state.cpp
index 6e14ffe..616e145 100644
--- a/src/system/kernel_state.cpp
+++ b/src/system/kernel_state.cpp
@@ -486,8 +486,13 @@ object_ref<XThread> KernelState::PrepareModuleLaunch(object_ref<UserModule> modu
 
   // Create a thread to run in.
   // We start suspended so the caller can inspect/attach before resume.
+  // start_context (r3) = -1 marks the main/process entry: XDK CRT entry thunks
+  // double as the thread trampoline and only run process init when r3 == -1
+  // (e.g. South Park LGTDP xstart: `cmpwi r3,-1; bne <epilogue>`). Passing 0 made
+  // the entry skip init and return immediately. (rexglue 0.8 passed 0.)
   auto thread = object_ref<XThread>(new XThread(
-      this, module->stack_size(), 0, module->entry_point(), 0, X_CREATE_SUSPENDED, true, true));
+      this, module->stack_size(), 0, module->entry_point(), 0xFFFFFFFF, X_CREATE_SUSPENDED, true,
+      true));
 
   // We know this is the 'main thread'.
   thread->set_name("Main XThread");
