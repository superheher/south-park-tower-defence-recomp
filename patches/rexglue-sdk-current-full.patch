diff --git a/include/rex/system/netplay.h b/include/rex/system/netplay.h
new file mode 100644
index 0000000..cc4f1fe
--- /dev/null
+++ b/include/rex/system/netplay.h
@@ -0,0 +1,86 @@
+/**
+ ******************************************************************************
+ * ReXGlue runtime — South Park: Let's Go Tower Defense online co-op
+ ******************************************************************************
+ * Netplay manager: bridges the title's Xbox 360 XGI/XNet calls to a local
+ * matchmaking broker (sp-netplay-server) so two instances on one host can find
+ * each other and exchange game UDP.
+ *
+ * Design (see sp-netplay-server/NIGHT-LOG.md): each instance is assigned a
+ * distinct loopback IP 127.0.0.(1+instance) via the --netplay_instance cvar and
+ * binds its game socket there; 127.0.0.0/8 all routes to loopback so distinct
+ * instances on the same port reach each other with no payload rewriting. The
+ * broker just matches host<->joiner and hands over each peer's XNADDR<->IP map.
+ *
+ * Entirely behind the --netplay_server cvar: when empty (default), enabled() is
+ * false and every hook is a no-op, so offline/single-player is unchanged.
+ ******************************************************************************
+ */
+#ifndef REX_SYSTEM_NETPLAY_H_
+#define REX_SYSTEM_NETPLAY_H_
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+namespace rex {
+namespace system {
+
+class Netplay {
+ public:
+  static Netplay& Get();
+
+  // True when --netplay_server is set (online co-op active). When false, all
+  // hooks below are inert and the title behaves exactly as offline.
+  bool enabled();
+
+  int instance();               // --netplay_instance (0,1,2,...)
+  std::string instance_id();    // "inst<N>"
+  uint32_t loopback_ip_net();   // network-order in_addr for 127.0.0.(1+N) (bind/resolve)
+  std::string loopback_ip_str();
+  uint32_t advertised_ip_net(); // non-loopback "online" IP for the advertised XNADDR
+                                // ina/inaOnline (identity only; reachability is via
+                                // abOnline -> XNetXnAddrToInAddr -> loopback)
+  const uint8_t* online_key();  // stable 20-byte abOnline identity for this instance
+  std::string online_key_hex();
+  uint16_t game_port();         // UDP port the game bound (default 1000)
+  void set_game_port(uint16_t p);
+
+  // Build the 36-byte XNADDR this instance advertises (ina/inaOnline = loopback
+  // ip, abOnline = online_key, abEnet = derived MAC). out must hold >=36 bytes.
+  void BuildSelfXnaddr(uint8_t* out36);
+
+  void EnsureRegistered();      // POST /register (idempotent) + start heartbeat
+
+  bool CreateSession(const std::string& session_id_hex, uint32_t flags,
+                     uint32_t pub, uint32_t priv, uint32_t game_type);
+
+  struct SessionResult {
+    std::string session_id_hex;       // 16 hex chars (8-byte XNKID)
+    std::string host_online_key_hex;  // 40 hex chars (20-byte abOnline)
+    uint32_t host_ip_net = 0;         // network order
+    uint16_t host_port = 0;
+    uint32_t open_pub = 0;
+    uint32_t open_priv = 0;
+    std::vector<uint8_t> host_xnaddr; // 36 bytes if the host published one
+  };
+
+  bool Search(uint32_t game_type, std::vector<SessionResult>& out);
+  bool Join(const std::string& session_id_hex, std::vector<SessionResult>& peers_out);
+  bool Leave(const std::string& session_id_hex);
+
+  // Resolve a peer's 20-byte abOnline -> loopback IP:port (broker, then cache).
+  bool Resolve(const uint8_t* online_key20, uint32_t& out_ip_net, uint16_t& out_port);
+
+  // Local peer cache (populated from search/join so Resolve is instant).
+  void CachePeer(const std::string& key_hex, uint32_t ip_net, uint16_t port);
+  bool LookupPeer(const std::string& key_hex, uint32_t& ip_net, uint16_t& port);
+
+ private:
+  Netplay() = default;
+};
+
+}  // namespace system
+}  // namespace rex
+
+#endif  // REX_SYSTEM_NETPLAY_H_
