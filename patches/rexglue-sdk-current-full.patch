+static void seh_dump_fault(EXCEPTION_POINTERS* p) {
+  static std::atomic<int> dumps{0};
+  if (dumps.fetch_add(1) >= 12) return;
+  if (!p || !p->ExceptionRecord || !p->ContextRecord) return;
+  auto* er = p->ExceptionRecord;
+  unsigned long long fault_addr =
+      (er->NumberParameters >= 2) ? (unsigned long long)er->ExceptionInformation[1] : 0ull;
+  HANDLE proc = GetCurrentProcess();
+  static std::atomic<bool> sym_done{false};
+  bool expected = false;
+  if (sym_done.compare_exchange_strong(expected, true)) {
+    SymSetOptions(SYMOPT_DEFERRED_LOADS | SYMOPT_UNDNAME | SYMOPT_LOAD_LINES);
+    SymInitialize(proc, nullptr, TRUE);
+  }
+  CONTEXT ctx = *p->ContextRecord;
+  STACKFRAME64 sf = {};
+  sf.AddrPC.Offset = ctx.Rip;     sf.AddrPC.Mode = AddrModeFlat;
+  sf.AddrFrame.Offset = ctx.Rbp;  sf.AddrFrame.Mode = AddrModeFlat;
+  sf.AddrStack.Offset = ctx.Rsp;  sf.AddrStack.Mode = AddrModeFlat;
+  std::string bt;
