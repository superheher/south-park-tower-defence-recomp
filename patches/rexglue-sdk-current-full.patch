+    if (!StackWalk64(IMAGE_FILE_MACHINE_AMD64, proc, GetCurrentThread(), &sf, &ctx, nullptr,
+                     SymFunctionTableAccess64, SymGetModuleBase64, nullptr))
+      break;
+    if (!sf.AddrPC.Offset) break;
+    char symbuf[sizeof(SYMBOL_INFO) + 512] = {};
+    auto* s = reinterpret_cast<SYMBOL_INFO*>(symbuf);
+    s->SizeOfStruct = sizeof(SYMBOL_INFO);
+    s->MaxNameLen = 511;
+    DWORD64 disp = 0;
+    if (SymFromAddr(proc, sf.AddrPC.Offset, &disp, s))
+      snprintf(buf, sizeof buf, "%s+0x%llX ", s->Name, (unsigned long long)disp);
+    else
+      snprintf(buf, sizeof buf, "0x%llX ", (unsigned long long)sf.AddrPC.Offset);
+    bt += buf;
+  }
+  REXLOG_WARN("SEH FAULT code=0x{:08X} fault_addr=0x{:X} tid={} bt: {}",
+              er->ExceptionCode, fault_addr, (unsigned)GetCurrentThreadId(), bt);
