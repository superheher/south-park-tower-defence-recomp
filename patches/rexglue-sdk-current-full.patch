+/**
+ ******************************************************************************
+ * ReXGlue runtime — South Park: Let's Go Tower Defense online co-op
+ ******************************************************************************
+ * Netplay manager implementation. Talks to the local matchmaking broker
+ * (sp-netplay-server) over a tiny synchronous loopback HTTP client built on the
+ * host's winsock (independent of the guest XSocket layer). The broker speaks a
+ * compact line-based text protocol (fmt=text) so no JSON parser is needed here.
+ *
+ * All activity is gated on the --netplay_server cvar; when unset the title is
+ * unchanged (offline/single-player path untouched).
+ ******************************************************************************
+ */
+#pragma GCC diagnostic ignored "-Wunused-parameter"
+
+#include <rex/system/netplay.h>
+
+#include <atomic>
+#include <chrono>
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <mutex>
+#include <sstream>
+#include <thread>
+#include <unordered_map>
+#include <utility>
+
+#include <rex/cvar.h>
+#include <rex/logging.h>
+
+#if defined(_WIN32)
+#define _WINSOCK_DEPRECATED_NO_WARNINGS
+#include <winsock2.h>
+#include <ws2tcpip.h>
+#pragma comment(lib, "ws2_32.lib")
+#endif
+
+// --- cvars (online co-op is entirely behind these) -------------------------
+REXCVAR_DEFINE_STRING(netplay_server, "", "Netplay",
+                      "Matchmaking broker URL (e.g. http://127.0.0.1:17890). "
+                      "Empty = offline (default).");
+REXCVAR_DEFINE_INT32(netplay_instance, 0, "Netplay",
+                     "This instance's index on a shared host. Selects loopback "
+                     "IP 127.0.0.(1+N) and a unique online identity.");
+
+namespace rex {
+namespace system {
+
+namespace {
+
+std::string g_server_host;  // parsed from --netplay_server
+int g_server_port = 0;
+std::once_flag g_wsa_once;
+std::mutex g_cache_mu;
+std::unordered_map<std::string, std::pair<uint32_t, uint16_t>> g_peer_cache;
+std::atomic<bool> g_registered{false};
+std::atomic<bool> g_hb_started{false};
+std::atomic<uint16_t> g_game_port{1000};
+uint8_t g_online_key[20] = {};
+bool g_key_built = false;
+
+void EnsureWsa() {
+#if defined(_WIN32)
+  std::call_once(g_wsa_once, []() {
+    WSADATA d;
+    WSAStartup(MAKEWORD(2, 2), &d);
+  });
+#endif
+}
+
+// Parse "http://127.0.0.1:17890" (or "127.0.0.1:17890") into host + port.
+void ParseServer(const std::string& url) {
+  std::string s = url;
+  auto pos = s.find("://");
+  if (pos != std::string::npos) s = s.substr(pos + 3);
+  auto slash = s.find('/');
+  if (slash != std::string::npos) s = s.substr(0, slash);
+  auto colon = s.find(':');
+  if (colon != std::string::npos) {
+    g_server_host = s.substr(0, colon);
+    g_server_port = std::atoi(s.substr(colon + 1).c_str());
+  } else {
+    g_server_host = s;
+    g_server_port = 80;
+  }
+}
+
+std::string ToHex(const uint8_t* p, size_t n) {
+  static const char* d = "0123456789abcdef";
+  std::string out;
+  out.resize(n * 2);
+  for (size_t i = 0; i < n; ++i) {
+    out[i * 2] = d[p[i] >> 4];
+    out[i * 2 + 1] = d[p[i] & 0xF];
+  }
+  return out;
+}
+
+size_t FromHex(const std::string& hex, uint8_t* out, size_t max) {
+  size_t n = 0;
+  for (size_t i = 0; i + 1 < hex.size() && n < max; i += 2) {
+    auto hv = [](char c) -> int {
+      if (c >= '0' && c <= '9') return c - '0';
+      if (c >= 'a' && c <= 'f') return c - 'a' + 10;
+      if (c >= 'A' && c <= 'F') return c - 'A' + 10;
+      return 0;
+    };
+    out[n++] = (uint8_t)((hv(hex[i]) << 4) | hv(hex[i + 1]));
+  }
+  return n;
+}
+
+// Synchronous HTTP POST of a JSON body, returns response body text. Always
+// appends "fmt":"text" so the broker replies in the compact line protocol.
+// Returns false on any transport error (server down etc.).
+bool HttpPost(const std::string& path, const std::string& json_fields,
+              std::string& body_out) {
+#if defined(_WIN32)
+  EnsureWsa();
+  if (g_server_host.empty()) return false;
+
+  SOCKET s = ::socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
+  if (s == INVALID_SOCKET) return false;
+
+  DWORD tmo = 2000;  // 2s; a missing broker must never hang the game
+  setsockopt(s, SOL_SOCKET, SO_RCVTIMEO, (const char*)&tmo, sizeof(tmo));
+  setsockopt(s, SOL_SOCKET, SO_SNDTIMEO, (const char*)&tmo, sizeof(tmo));
+
+  sockaddr_in addr = {};
+  addr.sin_family = AF_INET;
+  addr.sin_port = htons((u_short)g_server_port);
+  addr.sin_addr.s_addr = inet_addr(g_server_host.c_str());
+
+  if (::connect(s, (sockaddr*)&addr, sizeof(addr)) != 0) {
+    closesocket(s);
+    return false;
+  }
+
+  // Build the JSON body: { <fields>, "fmt":"text" }
+  std::string body = "{";
+  if (!json_fields.empty()) body += json_fields + ",";
+  body += "\"fmt\":\"text\"}";
+
+  std::ostringstream req;
+  req << "POST " << path << " HTTP/1.1\r\n"
+      << "Host: " << g_server_host << ":" << g_server_port << "\r\n"
+      << "Content-Type: application/json\r\n"
+      << "Content-Length: " << body.size() << "\r\n"
+      << "Connection: close\r\n\r\n"
+      << body;
+  std::string reqs = req.str();
+
+  size_t sent = 0;
+  while (sent < reqs.size()) {
+    int n = ::send(s, reqs.data() + sent, (int)(reqs.size() - sent), 0);
+    if (n <= 0) { closesocket(s); return false; }
+    sent += n;
+  }
+
+  std::string resp;
+  char buf[2048];
+  for (;;) {
+    int n = ::recv(s, buf, sizeof(buf), 0);
+    if (n <= 0) break;
+    resp.append(buf, n);
+  }
+  closesocket(s);
+
+  auto hdr_end = resp.find("\r\n\r\n");
+  if (hdr_end == std::string::npos) return false;
+  body_out = resp.substr(hdr_end + 4);
+  return true;
+#else
+  return false;
+#endif
+}
+
+// Quote a hex/string field as JSON.
+std::string J(const std::string& key, const std::string& val) {
+  return "\"" + key + "\":\"" + val + "\"";
+}
+std::string Jn(const std::string& key, long val) {
+  return "\"" + key + "\":" + std::to_string(val);
+}
+
+}  // namespace
+
+Netplay& Netplay::Get() {
+  static Netplay inst;
+  return inst;
+}
+
+bool Netplay::enabled() {
+  static std::once_flag parse_once;
+  std::call_once(parse_once, []() {
+    const std::string& url = REXCVAR_GET(netplay_server);
+    if (!url.empty()) ParseServer(url);
+  });
+  return !REXCVAR_GET(netplay_server).empty();
+}
+
+int Netplay::instance() { return REXCVAR_GET(netplay_instance); }
+
+std::string Netplay::instance_id() {
+  return "inst" + std::to_string(instance());
+}
+
+uint32_t Netplay::loopback_ip_net() {
+#if defined(_WIN32)
+  EnsureWsa();
+  return inet_addr(loopback_ip_str().c_str());
+#else
+  return 0;
+#endif
+}
+
+std::string Netplay::loopback_ip_str() {
+  return "127.0.0." + std::to_string(1 + instance());
+}
+
+uint32_t Netplay::advertised_ip_net() {
+#if defined(_WIN32)
+  EnsureWsa();
+  // A non-loopback, LAN-private, per-instance address. Real titles reject a
+  // loopback (127.x) as the online host address of a LIVE session; this is the
+  // address advertised in the XNADDR identity only — actual peer reachability is
+  // resolved via abOnline -> XNetXnAddrToInAddr -> loopback IP.
+  return inet_addr(("192.168.137." + std::to_string(20 + instance())).c_str());
+#else
+  return 0;
+#endif
+}
+
+const uint8_t* Netplay::online_key() {
+  if (!g_key_built) {
+    // Stable, unique-per-instance opaque identity. Layout is arbitrary; the
+    // broker treats it as an opaque key for matching.
+    std::memset(g_online_key, 0, sizeof(g_online_key));
+    g_online_key[0] = 'S'; g_online_key[1] = 'P';
+    g_online_key[2] = 'N'; g_online_key[3] = 'P';
+    g_online_key[4] = (uint8_t)instance();
+    uint32_t ip = loopback_ip_net();
+    std::memcpy(&g_online_key[5], &ip, 4);
+    g_key_built = true;
+  }
+  return g_online_key;
+}
+
+std::string Netplay::online_key_hex() { return ToHex(online_key(), 20); }
+
+uint16_t Netplay::game_port() { return g_game_port.load(); }
+void Netplay::set_game_port(uint16_t p) {
+  if (p) g_game_port.store(p);
+}
+
+void Netplay::BuildSelfXnaddr(uint8_t* out) {
+  std::memset(out, 0, 36);
+  uint32_t ip = advertised_ip_net();  // non-loopback online identity (see header)
+  std::memcpy(out + 0, &ip, 4);   // ina
+  std::memcpy(out + 4, &ip, 4);   // inaOnline
+  uint16_t p = htons(game_port());
+  std::memcpy(out + 8, &p, 2);    // wPortOnline (network order)
+  out[10] = 0x02; out[11] = 0x53; out[12] = 0x50;  // abEnet: locally-administered
+  out[13] = 0x00; out[14] = 0x00; out[15] = (uint8_t)(1 + instance());
+  std::memcpy(out + 16, online_key(), 20);          // abOnline
+}
+
+void Netplay::EnsureRegistered() {
+  if (!enabled() || g_registered.load()) return;
+
+  uint8_t xn[36];
+  BuildSelfXnaddr(xn);
+  std::string fields =
+      J("instanceId", instance_id()) + "," +
+      J("xnaddr", ToHex(xn, 36)) + "," +
+      J("onlineKey", online_key_hex()) + "," +
+      J("ip", loopback_ip_str()) + "," +
+      Jn("port", game_port()) + "," +
+      J("title", "south-park-lgtdp");
+  std::string resp;
+  if (HttpPost("/register", fields, resp) && resp.rfind("OK", 0) == 0) {
+    g_registered.store(true);
+    REXKRNL_INFO("[netplay] registered {} ip={} port={} key={}", instance_id(),
+                 loopback_ip_str(), game_port(), online_key_hex());
+  } else {
+    REXKRNL_WARN("[netplay] register failed (broker {}:{} reachable?)",
+                 g_server_host, g_server_port);
+  }
+
+  // Start a heartbeat thread once.
+  bool expected = false;
+  if (g_hb_started.compare_exchange_strong(expected, true)) {
+    std::thread([]() {
+      for (;;) {
+        std::this_thread::sleep_for(std::chrono::seconds(5));
+        auto& np = Netplay::Get();
+        if (!np.enabled()) continue;
+        std::string resp;
+        HttpPost("/heartbeat",
+                 J("instanceId", np.instance_id()) + "," + Jn("port", np.game_port()),
+                 resp);
+      }
+    }).detach();
+  }
+}
+
+bool Netplay::CreateSession(const std::string& session_id_hex, uint32_t flags,
+                            uint32_t pub, uint32_t priv, uint32_t game_type) {
+  if (!enabled()) return false;
+  EnsureRegistered();
+  uint8_t xn[36];
+  BuildSelfXnaddr(xn);
+  std::string fields =
+      J("instanceId", instance_id()) + "," +
+      J("sessionId", session_id_hex) + "," +
+      J("hostXnaddr", ToHex(xn, 36)) + "," +
+      Jn("flags", flags) + "," +
+      Jn("publicSlots", pub) + "," +
+      Jn("privateSlots", priv) + "," +
+      Jn("gameType", game_type);
+  std::string resp;
+  bool ok = HttpPost("/session/create", fields, resp) && resp.rfind("OK", 0) == 0;
+  REXKRNL_INFO("[netplay] CreateSession {} -> {}", session_id_hex,
+               ok ? "OK" : "FAIL");
+  return ok;
+}
+
+bool Netplay::Search(uint32_t game_type, std::vector<SessionResult>& out) {
+  out.clear();
+  if (!enabled()) return false;
+  EnsureRegistered();
+  std::string fields = J("instanceId", instance_id()) + "," + Jn("gameType", game_type);
+  std::string resp;
+  if (!HttpPost("/session/search", fields, resp)) return false;
+  std::istringstream iss(resp);
+  std::string line;
+  if (!std::getline(iss, line)) return false;
+  // header: "OK <n>"
+  if (line.rfind("OK", 0) != 0) return false;
+  int n = 0;
+  { std::istringstream h(line); std::string ok; h >> ok >> n; }
+  for (int i = 0; i < n && std::getline(iss, line); ++i) {
+    std::istringstream ls(line);
+    SessionResult r;
+    std::string ip, keyhex, xnhex;
+    int port = 0;
+    ls >> r.session_id_hex >> keyhex >> ip >> port >> r.open_pub >> r.open_priv >> xnhex;
+    if (keyhex != "-") r.host_online_key_hex = keyhex;
+    if (ip != "-") r.host_ip_net = inet_addr(ip.c_str());
+    r.host_port = (uint16_t)port;
+    if (xnhex != "-") {
+      r.host_xnaddr.resize(36);
+      FromHex(xnhex, r.host_xnaddr.data(), 36);
+    }
+    // cache for instant resolve
+    if (!r.host_online_key_hex.empty() && r.host_ip_net)
+      CachePeer(r.host_online_key_hex, r.host_ip_net, r.host_port);
+    out.push_back(std::move(r));
+  }
+  REXKRNL_INFO("[netplay] Search gameType={} -> {} session(s)", game_type, out.size());
+  return true;
+}
+
+bool Netplay::Join(const std::string& session_id_hex,
+                   std::vector<SessionResult>& peers_out) {
+  peers_out.clear();
+  if (!enabled()) return false;
+  EnsureRegistered();
+  uint8_t xn[36];
+  BuildSelfXnaddr(xn);
+  std::string fields = J("instanceId", instance_id()) + "," +
+                       J("sessionId", session_id_hex) + "," +
+                       J("xnaddr", ToHex(xn, 36));
+  std::string resp;
+  if (!HttpPost("/session/join", fields, resp)) return false;
+  std::istringstream iss(resp);
+  std::string line;
+  if (!std::getline(iss, line) || line.rfind("OK", 0) != 0) return false;
+  while (std::getline(iss, line)) {
+    if (line.empty()) continue;
+    std::istringstream ls(line);
+    std::string id, keyhex, ip, xnhex;
+    int port = 0;
+    ls >> id >> keyhex >> ip >> port >> xnhex;
+    SessionResult r;
+    if (keyhex != "-") r.host_online_key_hex = keyhex;
+    if (ip != "-") r.host_ip_net = inet_addr(ip.c_str());
+    r.host_port = (uint16_t)port;
+    if (!r.host_online_key_hex.empty() && r.host_ip_net)
+      CachePeer(r.host_online_key_hex, r.host_ip_net, r.host_port);
+    peers_out.push_back(std::move(r));
+  }
+  REXKRNL_INFO("[netplay] Join {} -> {} peer(s)", session_id_hex, peers_out.size());
+  return true;
+}
+
+bool Netplay::Leave(const std::string& session_id_hex) {
+  if (!enabled()) return false;
+  std::string fields = J("instanceId", instance_id()) + "," +
+                       J("sessionId", session_id_hex);
+  std::string resp;
+  return HttpPost("/session/leave", fields, resp);
+}
+
+bool Netplay::Resolve(const uint8_t* key20, uint32_t& out_ip_net, uint16_t& out_port) {
+  if (!enabled()) return false;
+  std::string keyhex = ToHex(key20, 20);
+  if (LookupPeer(keyhex, out_ip_net, out_port)) return true;
+  std::string resp;
+  if (!HttpPost("/resolve", J("onlineKey", keyhex), resp)) return false;
+  if (resp.rfind("OK", 0) != 0) return false;
+  std::istringstream ls(resp);
+  std::string ok, ip, id;
+  int port = 0;
+  ls >> ok >> ip >> port >> id;
+  out_ip_net = inet_addr(ip.c_str());
+  out_port = (uint16_t)port;
+  CachePeer(keyhex, out_ip_net, out_port);
+  REXKRNL_INFO("[netplay] Resolve {} -> {}:{}", keyhex.substr(0, 12), ip, port);
+  return true;
+}
+
+void Netplay::CachePeer(const std::string& key_hex, uint32_t ip_net, uint16_t port) {
+  std::lock_guard<std::mutex> lk(g_cache_mu);
+  g_peer_cache[key_hex] = {ip_net, port};
+}
+
+bool Netplay::LookupPeer(const std::string& key_hex, uint32_t& ip_net, uint16_t& port) {
+  std::lock_guard<std::mutex> lk(g_cache_mu);
+  auto it = g_peer_cache.find(key_hex);
+  if (it == g_peer_cache.end()) return false;
+  ip_net = it->second.first;
+  port = it->second.second;
+  return true;
+}
+
+}  // namespace system
+}  // namespace rex
