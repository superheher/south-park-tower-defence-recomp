+// [recomp audio-dump] When set, append the exact interleaved F32LE PCM we hand to SDL
+// to this raw file, so the decoded game audio can be auditioned/inspected offline (the
+// XMA->SDL path is objectively correct, but fidelity needs a human ear). Captures BOTH
+// real frames and silence gaps, so the clip is real-time accurate. Post-convert with:
+//   ffmpeg -f f32le -ar 48000 -ac <channels> -i <file> out.wav
+// (channels = 2 or 6; logged once when the dump opens).
+REXCVAR_DEFINE_STRING(audio_dump, "", "Audio",
+                      "If non-empty, write the interleaved F32LE PCM sent to SDL to this raw file");
+
+// Appends the interleaved PCM block to the audio_dump file (opened once, on the SDL audio
+// callback thread only -- no locking needed). No-op unless the cvar is set.
+static void AppendAudioDump(const float* data, int len_bytes, unsigned channels) {
+  const std::string& path = REXCVAR_GET(audio_dump);
+  if (path.empty()) {
+    return;
+  }
+  static std::ofstream dump_stream;
+  static bool open_attempted = false;
+  if (!open_attempted) {
+    open_attempted = true;
+    dump_stream.open(path, std::ios::binary | std::ios::trunc);
+    if (dump_stream.is_open()) {
+      REXAPU_INFO(
+          "audio_dump: capturing {}-channel F32LE @48000Hz to '{}' "
+          "(convert: ffmpeg -f f32le -ar 48000 -ac {} -i <file> out.wav)",
+          channels, path, channels);
+    } else {
+      REXAPU_ERROR("audio_dump: failed to open '{}'", path);
+    }
+  }
+  if (dump_stream.is_open()) {
+    dump_stream.write(reinterpret_cast<const char*>(data), len_bytes);
+  }
+}
