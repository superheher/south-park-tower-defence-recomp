+// there, e.g. the "levels reached" counter at g_slots+2520 goes 1->3; this block is all
+// small ints/flags, NO pointers, and is what the level-select's level grid is built
+// from). On SAVE the game serializes it to the title-profile blob 63E83FFE (runtime
+// persists it fine). On a fresh boot the guest reads 63E83FFE back (PROF-RD is_set=true)
+// but never deserializes it into this g_slots block -> the block stays default ->
+// CAMPAIGN LEVEL SELECT shows only Stan's House after a restart. Pure-disk preservation
+// can't fix it (the grid is built from g_slots, not the disk). Fix: persist this g_slots
+// block to a side file on save, and restore it into g_slots every frame whenever the
+// live "levels reached" gate is LOWER than the saved one (i.e. a fresh/default block),
+// so the saved progress is in place before the level-select reads it. The gate makes it
+// monotonic: in-session wins (gate goes >= saved) are kept and grow the snapshot; a
+// reset/default block (gate < saved) is restored. Raw bytes -> format-agnostic. See KB
+// 56-continue-re-map.md.
+namespace {
+constexpr uint32_t kCampaignGSlots = 0x828EB348u;
+constexpr int kCampaignProgOff = 2480;  // campaign progress block in slot 0 (ints/flags, no pointers)
+constexpr int kCampaignProgLen = 144;   // g_slots+2480 .. +2624
+constexpr int kCampaignGateOff = 40;    // prog[40] == g_slots+2520 = monotonic "levels reached" gate
+std::array<uint8_t, kCampaignProgLen> g_campaign_snap{};
+std::mutex g_campaign_mtx;                  // guards g_campaign_snap + the side file
+std::atomic<bool> g_campaign_loaded{false};
+std::atomic<bool> g_campaign_thread{false};
+
+std::filesystem::path CampaignSidePath() {
+  return REX_KERNEL_STATE()->content_manager()->ResolveGameUserContentPath() / "gslots_campaign.bin";
+}
+uint8_t* CampaignProg() {
+  uint8_t* g = REX_KERNEL_MEMORY()->TranslateVirtual<uint8_t*>(kCampaignGSlots);
+  return g ? g + kCampaignProgOff : nullptr;
+}
+void CampaignWriteSideFileLocked() {  // caller holds g_campaign_mtx
+  auto path = CampaignSidePath();
+  std::error_code ec;
+  std::filesystem::create_directories(path.parent_path(), ec);
+  if (FILE* f = rex::filesystem::OpenFile(path, "wb")) {
+    fwrite(g_campaign_snap.data(), 1, g_campaign_snap.size(), f);
+    fclose(f);
+    REXKRNL_WARN("[CONT-FIX] saved campaign progress snapshot (gate={})",
+                 (int)g_campaign_snap[kCampaignGateOff]);
+  }
+}
+void CampaignEnsureLoaded() {
+  if (g_campaign_loaded.exchange(true)) return;
+  std::lock_guard<std::mutex> lk(g_campaign_mtx);
+  g_campaign_snap.fill(0);
+  if (FILE* f = rex::filesystem::OpenFile(CampaignSidePath(), "rb")) {
+    fread(g_campaign_snap.data(), 1, g_campaign_snap.size(), f);
+    fclose(f);
+    REXKRNL_WARN("[CONT-FIX] loaded campaign progress snapshot (gate={})",
+                 (int)g_campaign_snap[kCampaignGateOff]);
+  }
+}
+// Capture the live block IF it is more progressed than the snapshot. The campaign
+// progress block at g_slots+2480 is only populated TRANSIENTLY around a level win (it is
+// 0 at the menu), so this is polled at high frequency from a background thread to reliably
+// catch that brief window (the game's own profile-write clobbers progress to default, so
+// hooking it is useless). gate (g_slots+2520) = monotonic "levels reached".
+void CampaignCaptureIfGrew() {
+  uint8_t* prog = CampaignProg();
+  if (!prog) return;
+  int gate_cur = prog[kCampaignGateOff];
+  std::lock_guard<std::mutex> lk(g_campaign_mtx);
+  if (gate_cur > g_campaign_snap[kCampaignGateOff] && gate_cur <= 30) {
+    std::memcpy(g_campaign_snap.data(), prog, kCampaignProgLen);
+    CampaignWriteSideFileLocked();
+  }
+}
+void CampaignThreadFn() {
+  CampaignEnsureLoaded();
+  for (;;) {
+    CampaignCaptureIfGrew();
+    std::this_thread::sleep_for(std::chrono::milliseconds(20));
+  }
+}
+}  // namespace
+
+// Called per frame from XamInputGetState. Starts the capture thread once, then RESTORES
+// the saved progress into the live g_slots block whenever it reads as default/less
+// progressed (fresh boot, menu, level-select) so the campaign level grid is rebuilt with
+// the saved unlocks. Capture (catching the transient win state) is done by the thread.
+void CampaignContinueRestore() {
+  CampaignEnsureLoaded();
+  if (!g_campaign_thread.exchange(true)) {
+    std::thread(CampaignThreadFn).detach();
+  }
+  uint8_t* prog = CampaignProg();
+  if (!prog) return;
+  std::lock_guard<std::mutex> lk(g_campaign_mtx);
+  int gate_snap = g_campaign_snap[kCampaignGateOff];
+  if (gate_snap > 0 && prog[kCampaignGateOff] < gate_snap) {
+    std::memcpy(prog, g_campaign_snap.data(), kCampaignProgLen);  // restore saved progress
+  } else if (prog[kCampaignGateOff] > gate_snap && prog[kCampaignGateOff] <= 30) {
+    std::memcpy(g_campaign_snap.data(), prog, kCampaignProgLen);  // also capture here
+    CampaignWriteSideFileLocked();
+  }
+}
+
+// Backup capture on the game's profile-write.
+void CampaignContinueSnapshot() { CampaignCaptureIfGrew(); }
