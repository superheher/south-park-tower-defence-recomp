 namespace rex::platform {
 
 static thread_local SehThreadState tls_seh_state;
 static thread_local bool tls_seh_active = false;
 
+// [diag] Symbolized backtrace of an SEH-caught hardware fault. The recovery
+// (return-to-caller-as-failure) otherwise hides where a guest worker faulted,
+// which can stall the boot. Capped + first-fault-symbol-init to stay cheap.
+static void seh_dump_fault(EXCEPTION_POINTERS* p) {
+  static std::atomic<int> dumps{0};
+  if (dumps.fetch_add(1) >= 12) return;
+  if (!p || !p->ExceptionRecord || !p->ContextRecord) return;
+  auto* er = p->ExceptionRecord;
+  unsigned long long fault_addr =
+      (er->NumberParameters >= 2) ? (unsigned long long)er->ExceptionInformation[1] : 0ull;
+  HANDLE proc = GetCurrentProcess();
+  static std::atomic<bool> sym_done{false};
+  bool expected = false;
+  if (sym_done.compare_exchange_strong(expected, true)) {
+    SymSetOptions(SYMOPT_DEFERRED_LOADS | SYMOPT_UNDNAME | SYMOPT_LOAD_LINES);
+    SymInitialize(proc, nullptr, TRUE);
+  }
+  CONTEXT ctx = *p->ContextRecord;
+  STACKFRAME64 sf = {};
+  sf.AddrPC.Offset = ctx.Rip;     sf.AddrPC.Mode = AddrModeFlat;
+  sf.AddrFrame.Offset = ctx.Rbp;  sf.AddrFrame.Mode = AddrModeFlat;
+  sf.AddrStack.Offset = ctx.Rsp;  sf.AddrStack.Mode = AddrModeFlat;
+  std::string bt;
+  char buf[640];
+  for (int i = 0; i < 16; ++i) {
+    if (!StackWalk64(IMAGE_FILE_MACHINE_AMD64, proc, GetCurrentThread(), &sf, &ctx, nullptr,
+                     SymFunctionTableAccess64, SymGetModuleBase64, nullptr))
+      break;
+    if (!sf.AddrPC.Offset) break;
+    char symbuf[sizeof(SYMBOL_INFO) + 512] = {};
+    auto* s = reinterpret_cast<SYMBOL_INFO*>(symbuf);
+    s->SizeOfStruct = sizeof(SYMBOL_INFO);
+    s->MaxNameLen = 511;
+    DWORD64 disp = 0;
+    if (SymFromAddr(proc, sf.AddrPC.Offset, &disp, s))
+      snprintf(buf, sizeof buf, "%s+0x%llX ", s->Name, (unsigned long long)disp);
+    else
+      snprintf(buf, sizeof buf, "0x%llX ", (unsigned long long)sf.AddrPC.Offset);
+    bt += buf;
+  }
+  REXLOG_WARN("SEH FAULT code=0x{:08X} fault_addr=0x{:X} tid={} bt: {}",
+              er->ExceptionCode, fault_addr, (unsigned)GetCurrentThreadId(), bt);
+}
