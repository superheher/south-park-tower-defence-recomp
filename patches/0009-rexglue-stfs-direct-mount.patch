+  // file straight from the user's own console dump (StfsContainerDevice). Auto-detect
+  // by file-vs-directory so no extraction step is required.
   auto mount_path = "\\Device\\Harddisk0\\Partition1";
-  auto device = std::make_unique<rex::filesystem::HostPathDevice>(
