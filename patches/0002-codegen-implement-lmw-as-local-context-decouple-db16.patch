+++ b/include/rex/codegen/function_graph.h
@@ -95,6 +95,14 @@ class FunctionGraph {
   // Get all SEALED functions
   std::vector<FunctionNode*> getSealedFunctions();
 
+  // P2 leaf-inlining: mark tiny straight-line leaves as inline-eligible (sets FunctionNode::
+  // isInlineLeaf()). Must run after sealing and rexcrt renaming, before codegen emission, so that
+  // call-site emission can route eligible callees to the always_inline variant. Excludes imports,
+  // rexcrt CRT replacements (passed in rexcrtAddrs), functions with calls/tailcalls/jumptables,
+  // SEH/EH, an LR data-read (mflr/mfspr-LR), a mid-asm hook in their body, or size > maxBytes.
+  void markInlineLeaves(const RecompilerConfig& cfg,
+                        const std::unordered_set<uint32_t>& rexcrtAddrs, uint32_t maxBytes);
+
   // Statistics
   size_t functionCount() const { return functions_.size(); }
