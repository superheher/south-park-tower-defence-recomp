diff --git a/src/codegen/builders/context.cpp b/src/codegen/builders/context.cpp
index 6eae29d..276ba01 100644
--- a/src/codegen/builders/context.cpp
+++ b/src/codegen/builders/context.cpp
@@ -177,12 +177,45 @@ void BuilderContext::emit_function_call(uint32_t address) {
   }
 
   if (address == cfg.setJmpAddress) {
-    // Save PPCContext for restoration after longjmp
+    // [CODEGEN-ASLOCAL] setjmp/longjmp ctx-snapshot sync.
+    // When registers/flags are promoted to C++ locals (cr/xer/ctr/reserved/GPR-as-local),
+    // the LIVE values are NOT in ctx. setjmp snapshots the whole ctx (env = ctx) and a
+    // longjmp restores it (ctx = env); without help, the longjmp would resurrect STALE
+    // ctx register state. We keep PPCContext full (see the init_h.inja DECOUPLE note) and
+    // sync the promoted set around the snapshot: save locals -> ctx before env=ctx, then
+    // reload locals <- ctx after ctx=env. The promoted set is enumerated from the config
+    // flags; we sync the whole register class (not only regs used so far) for
+    // unconditional correctness -- clang DCEs any that are dead. setjmp sites are rare
+    // (image-format detection) so the extra stores are negligible.
+    const int kNonArgGpr[] = {0, 2, 11, 12};
+    auto forEachPromoted = [&](auto&& fn) {
+      if (cfg.crRegistersAsLocalVariables)
+        for (int i = 0; i < 8; ++i) { locals.cr[i] = true; fn(fmt::format("cr{}", i), fmt::format("ctx.cr{}", i)); }
+      if (cfg.xerAsLocalVariable)              { locals.xer = true;      fn("xer", "ctx.xer"); }
+      if (cfg.ctrAsLocalVariable)              { locals.ctr = true;      fn("ctr", "ctx.ctr"); }
+      if (cfg.reservedRegisterAsLocalVariable) { locals.reserved = true; fn("reserved", "ctx.reserved"); }
+      if (cfg.nonVolatileRegistersAsLocalVariables) {
+        for (int i = 14; i <= 31; ++i)  { locals.r[i] = true; fn(fmt::format("r{}", i), fmt::format("ctx.r{}", i)); }
+        for (int i = 14; i <= 31; ++i)  { locals.f[i] = true; fn(fmt::format("f{}", i), fmt::format("ctx.f{}", i)); }
+        for (int i = 14; i <= 31; ++i)  { locals.v[i] = true; fn(fmt::format("v{}", i), fmt::format("ctx.v{}", i)); }
+        for (int i = 64; i <= 127; ++i) { locals.v[i] = true; fn(fmt::format("v{}", i), fmt::format("ctx.v{}", i)); }
+      }
+      if (cfg.nonArgumentRegistersAsLocalVariables) {
+        for (int i : kNonArgGpr)        { locals.r[i] = true; fn(fmt::format("r{}", i), fmt::format("ctx.r{}", i)); }
+        locals.f[0] = true; fn("f0", "ctx.f0");
+        for (int i = 32; i <= 63; ++i)  { locals.v[i] = true; fn(fmt::format("v{}", i), fmt::format("ctx.v{}", i)); }
+      }
+    };
+    // 1) save promoted locals -> ctx, then snapshot the (now-coherent) ctx
+    forEachPromoted([&](const std::string& reg, const std::string& cx) { println("\t{} = {};", cx, reg); });
     println("\t{} = ctx;", env());
-    // Use custom ppc_setjmp that uses guest address as key
+    // 2) custom ppc_setjmp keyed by guest address
     println("\t{}.s64 = ppc_setjmp({}.u32);", temp(), r(3));
-    // Restore PPCContext if returning from longjmp
-    println("\tif ({}.s64 != 0) ctx = {};", temp(), env());
+    // 3) on longjmp return (!=0): restore whole ctx, then reload promoted locals <- ctx
+    println("\tif ({}.s64 != 0) {{", temp());
+    println("\t\tctx = {};", env());
+    forEachPromoted([&](const std::string& reg, const std::string& cx) { println("\t\t{} = {};", reg, cx); });
+    println("\t}}");
     println("\t{} = {};", r(3), temp());
     return;
   }
@@ -200,6 +233,14 @@ void BuilderContext::emit_function_call(uint32_t address) {
         return;
       }
 
+      // P2: route a call to an inline-eligible leaf to its always_inline variant (defined in
+      // {project}_inlines.h). The out-of-line thunk + weak alias `name` still exist (dispatch/
+      // overrides unaffected); this is what actually inlines the leaf and drops the call site.
+      if (targetFn->isInlineLeaf()) {
+        println("\t{}_inl(ctx, base);", name);
+        return;
+      }
+
       println("\t{}(ctx, base);", name);
       return;
     }
