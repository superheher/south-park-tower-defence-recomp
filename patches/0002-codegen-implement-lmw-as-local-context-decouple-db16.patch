 }
 
 bool build_db16cyc(BuilderContext& ctx) {
-  // Xenon-specific 16-cycle delay hint, no effect in recompiled code
-  (void)ctx;
+  // Xenon 16-cycle backoff hint used in spin-waits (cctpl..db16cyc..cctpm). Emitting it as a no-op
+  // makes recompiled guest spin-waits hog a host core at full speed (measured: the guest burns
+  // ~5.3G insn/s even while PAUSED). Map it to a real backoff: x86 PAUSE + a periodic host yield so
+  // the thread/GPU that satisfies the wait gets scheduled. No guest-visible effect. See REX_SPIN_BACKOFF.
+  ctx.println("\tREX_SPIN_BACKOFF();");
   return true;
 }
 
