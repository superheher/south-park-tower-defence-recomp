+void FunctionGraph::markInlineLeaves(const RecompilerConfig& cfg,
+                                     const std::unordered_set<uint32_t>& rexcrtAddrs,
+                                     uint32_t maxBytes) {
+  size_t n = 0;
+  for (auto& [addr, nodeptr] : functions_) {
+    FunctionNode* fn = nodeptr.get();
+    fn->inlineLeaf_ = false;
+    if (!fn->isSealed())
+      continue;
+    if (fn->authority() == FunctionAuthority::IMPORT)
+      continue;
+    if (rexcrtAddrs.contains(fn->base()))  // rexcrt CRT replacements are emitted separately
+      continue;
+    if (fn->blocks().empty())  // stub
+      continue;
+    if (!fn->calls().empty() || !fn->tailCalls().empty())  // not a leaf (no bl/bctrl/blrl out)
+      continue;
+    if (!fn->jumpTables().empty())  // indirect dispatch (bctr switch)
+      continue;
+    if (fn->hasExceptionInfo() || fn->hasExceptionHandler())  // no SEH/C++ EH/setjmp frame
+      continue;
+    if (fn->size() == 0 || fn->size() > maxBytes)
+      continue;
+
+    bool ok = true;
+    // Exclude an LR DATA read (mflr / mfspr SPR_LR): inlining would capture the CALLER's return
+    // address, not the leaf's. A terminal/return blr also "reads_lr" but is_return/is_branch -- it
+    // just becomes fallthrough when inlined, which is correct, so it is allowed.
+    for (auto* insn : fn->instructions()) {
+      auto sem = insn->get_semantics();
+      if (sem.reads_lr && !sem.is_return && !sem.is_branch) {
+        ok = false;
+        break;
+      }
+    }
+    if (!ok)
+      continue;
+    // Exclude any function whose body contains a mid-asm hook address: a hook must fire at one fixed
+    // address, not at N inlined copies.
+    if (!cfg.midAsmHooks.empty()) {
+      for (uint32_t a = fn->base(); a < fn->end(); a += 4) {
+        if (cfg.midAsmHooks.contains(a)) {
+          ok = false;
+          break;
+        }
+      }
+    }
+    if (!ok)
+      continue;
+
+    fn->inlineLeaf_ = true;
+    ++n;
+  }
+  REXCODEGEN_TRACE("markInlineLeaves: {} inline-eligible leaves (maxBytes={})", n, maxBytes);
+}
