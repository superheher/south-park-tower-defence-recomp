--- a/src/codegen/builders/memory.cpp
+++ b/src/codegen/builders/memory.cpp
@@ -395,6 +395,25 @@ bool build_stmw(BuilderContext& ctx) {
   return true;
 }
 
+bool build_lmw(BuilderContext& ctx) {
+  // EA = (rA == 0 ? 0 : r[rA]) + EXTS(d); load r[rD]..r[31] from EA, EA+4, ...
+  // Load-multiple mirror of build_stmw (function epilogues pair lmw with the
+  // prologue's stmw to restore non-volatile GPRs). Without this, any function
+  // using the stmw/lmw save-restore pattern compiles its prologue but throws
+  // REX_UNIMPLEMENTED in its epilogue.
+  uint32_t rD = ctx.insn.operands[0];
+  int32_t offset = static_cast<int32_t>(ctx.insn.operands[1]);
+  uint32_t rA = ctx.insn.operands[2];
+  if (rA != 0)
+    ctx.println("\t{} = {}.u32 + {};", ctx.ea(), ctx.r(rA), offset);
+  else
+    ctx.println("\t{} = {};", ctx.ea(), offset);
+  for (uint32_t i = rD; i <= 31; ++i) {
+    ctx.println("\t{}.u64 = REX_LOAD_U32({} + {});", ctx.r(i), ctx.ea(), (i - rD) * 4);
+  }
+  return true;
+}
