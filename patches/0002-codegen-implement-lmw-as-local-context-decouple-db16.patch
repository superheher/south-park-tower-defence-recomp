 {% endif %}{% if config_flags.skip_msr %}#define REX_CONFIG_SKIP_MSR
-{% endif %}{% if config_flags.cr_as_local %}#define REX_CONFIG_CR_AS_LOCAL
-{% endif %}{% if config_flags.non_argument_as_local %}#define REX_CONFIG_NON_ARGUMENT_AS_LOCAL
-{% endif %}{% if config_flags.non_volatile_as_local %}#define REX_CONFIG_NON_VOLATILE_AS_LOCAL
 {% endif %}
+// [CODEGEN-ASLOCAL] DECOUPLE: the REX_CONFIG_*_AS_LOCAL macros are intentionally NOT
+// emitted here. In rex/ppc/context.h they are guarded around PPCContext members, so
+// defining them SHRINKS the struct -- but the prebuilt librexruntime.so is compiled
+// WITHOUT them (port<->.so layout mismatch: cr0-7/xer/ctr/nonvol GPRs removed, shifting
+// fpscr/f*/v*), and this title's setjmp (env=ctx / ctx=env) + SEH snapshot the WHOLE ctx.
+// Instead we keep the PPCContext layout FULL (struct unchanged => .so matches, and env=ctx
+// still has a ctx.cr/ctx.r* to snapshot) while the codegen STILL emits the registers as
+// per-function C++ locals (the clang-DCE + register-allocation .text win). The promoted
+// locals are synced <-> ctx only at the snapshot boundaries: setjmp (builders/context.cpp)
+// and SEH (function_graph.cpp, for GPRs). The *_as_local config flags still drive the
+// accessor + local-declaration emission in the codegen tool. See docs/CODEGEN-ASLOCAL-PLAN.md.
 #define REX_IMAGE_BASE {{ image_base }}ull
 #define REX_IMAGE_SIZE {{ image_size }}ull
 #define REX_CODE_BASE {{ code_base }}ull
@@ -36,6 +41,7 @@
 #include <rex/perf/counter.h>
 #include <rex/thread/mutex.h>
 #include <rex/system/mmio_handler.h>
+#include <rex/platform/exceptions.h>  // SEH_TRY/SEH_CATCH_ALL for generate_exception_handlers
 
 #include <atomic>
 #include <cassert>
@@ -43,8 +49,29 @@
 #include <cstdlib>
 #include <stdexcept>
 #include <string_view>
+#include <thread>
 #include <unordered_map>
 
+//=============================================================================
+// Spin-wait backoff (guest db16cyc / cctpl..cctpm spin-wait idiom)
+//=============================================================================
+// Xenon titles bracket a spin-wait with `cctpl` (set thread priority LOW) ... `db16cyc` (16-cycle
+// backoff, repeated) ... `cctpm` (restore priority). Emitting these as pure no-ops makes the
+// recompiled guest spin a host core at FULL speed/priority, burning ~5.3 G instructions/s even while
+// the game is PAUSED -- and starving the guest thread/GPU that will satisfy the wait. Map the
+// `db16cyc` backoff to a real x86 PAUSE (frees the SMT sibling, cuts power/thermal) plus a *periodic*
+// host yield so the condition-setter actually gets scheduled and the wait exits. This is a pure
+// backoff/scheduling hint: it changes NO guest-visible result (the loop still re-checks the same
+// condition), it only stops the busy-wait from hogging the core. See FLOOR-OVEREXEC report.
+static inline void rex_spin_backoff() noexcept {
+#if (defined(__x86_64__) || defined(__i386__)) && (defined(__GNUC__) || defined(__clang__))
+  __builtin_ia32_pause();
+#endif
+  static thread_local unsigned rex_sb_ctr = 0;
+  if ((++rex_sb_ctr & 0x3FFFu) == 0u) std::this_thread::yield();
+}
+#define REX_SPIN_BACKOFF() rex_spin_backoff()
+
 //=============================================================================
 // Image Info
 //=============================================================================
@@ -64,6 +91,13 @@ extern PPCFuncMapping PPCFuncMappings[];
   __attribute__((alias("__imp__" #name))) REX_WEAK_FUNC(name); \
   REX_EXTERN(__imp__##name)
 
+// P2 leaf-inlining: an inline-eligible leaf gets an always_inline body `name##_inl` here (in the
+// shared {project}_inlines.h, included at the end of this file) in addition to the normal out-of-line
+// DEFINE_REX_FUNC(name) thunk + weak alias. Eligible call sites call `name##_inl(ctx, base)` so the
+// body inlines; dispatch table + overrides still use the out-of-line `name`/`__imp__name`.
+#define STATIC_INLINE_REX_FUNC(name) \
+  [[gnu::always_inline, maybe_unused]] static inline REX_FUNC(name##_inl)
+
 //=============================================================================
 // Function Prologue
 //=============================================================================
@@ -318,3 +352,9 @@ inline std::atomic<i32>& ppc_global_lock_count_() {
 
 {% for fn in functions %}DECLARE_REX_FUNC({{ fn.name }});
 {% endfor %}
+
+//=============================================================================
+// Inline-eligible leaf bodies (P2). Included LAST: needs the macros/types above + the __imp__
+// declarations, and must be visible in every recomp TU so the always_inline leaves inline.
+//=============================================================================
+#include "{{ project }}_inlines.h"
