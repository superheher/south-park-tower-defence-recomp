Subject: [PATCH 11/13] system/loader: r1 stack headroom, entry override, boot
 continuation, STFS direct mount


diff --git a/src/filesystem/devices/host_path_entry.cpp b/src/filesystem/devices/host_path_entry.cpp
index 56f5a97..e39c435 100644
--- a/src/filesystem/devices/host_path_entry.cpp
+++ b/src/filesystem/devices/host_path_entry.cpp
@@ -12,6 +12,12 @@
 #include <rex/filesystem/devices/host_path_entry.h>
 #include <rex/filesystem/devices/host_path_file.h>
 
+#include <algorithm>
