Subject: [PATCH 06/13] graphics: vulkan/texture/shared-memory bring-up fixes


diff --git a/include/rex/graphics/pipeline/texture/cache.h b/include/rex/graphics/pipeline/texture/cache.h
index d1580fc..0856b16 100644
--- a/include/rex/graphics/pipeline/texture/cache.h
+++ b/include/rex/graphics/pipeline/texture/cache.h
@@ -228,6 +228,11 @@ class TextureCache {
     }
     void MakeUpToDateAndWatch(const std::unique_lock<std::recursive_mutex>& global_lock);
 
+    // [recomp fix: font-glyph striping — KB 65, ironclad pt3] If a base reload is pending to catch a
+    // settled CPU glyph memcpy (see base_recheck_frames_), consume one frame: re-mark the base
+    // outdated so it reloads this pass, and return true. Returns false when nothing is pending.
+    bool ConsumeBaseRecheckFrame(const std::unique_lock<std::recursive_mutex>& global_lock);
+
     void WatchCallback(const std::unique_lock<std::recursive_mutex>& global_lock, bool is_mip);
 
     // For LRU caching - updates the last usage frame and moves the texture to
@@ -269,6 +274,20 @@ class TextureCache {
     bool base_outdated_ = false;
     // Whether the recent mip data needs reloading from the memory.
     bool mips_outdated_ = false;
+    // [recomp fix: font-glyph striping — KB 65, ironclad pt3] The host write-watch is one-shot: the
+    // first guest write to a watched range fires the callback and cancels the watch, and the wide
+    // invalidation drops page protection so the REST of a multi-page CPU glyph memcpy does not
+    // re-fault. If the texture is loaded mid-memcpy (true even for the very FIRST/creation load of
+    // the in-match hint banner), its tail pages capture stale bytes and are never reloaded (loads=1)
+    // -> persistent, timing-dependent vertical-striped text. After any load triggered by a real
+    // reason (creation or a guest write), force a couple extra reloads on the following frames so the
+    // settled memcpy is captured. base_arm_recheck_on_load_ is set ONLY by creation and the write
+    // callback (NOT by these forced rechecks), so the recheck cannot loop.
+    bool base_arm_recheck_on_load_ = false;
+    uint8_t base_recheck_frames_ = 0;
+    // Gates recheck consumption to one per GPU submission so the extra reloads span real frames
+    // (giving a multi-page CPU glyph memcpy time to settle), not multiple draws within one frame.
+    uint64_t base_recheck_last_submission_ = 0;
     std::atomic<uint32_t> outdated_mask_{0};
     // Watch handles for the memory ranges.
     SharedMemory::WatchHandle base_watch_handle_ = nullptr;
diff --git a/include/rex/graphics/shared_memory.h b/include/rex/graphics/shared_memory.h
index b05df6a..00155f2 100644
--- a/include/rex/graphics/shared_memory.h
+++ b/include/rex/graphics/shared_memory.h
@@ -77,7 +77,17 @@ class SharedMemory {
   // Checks if the range has been updated, uploads new data if needed and
   // ensures the host GPU memory backing the range are resident. Returns true if
   // the range has been fully updated and is usable.
-  bool RequestRanges(const std::pair<uint32_t, uint32_t>* ranges, size_t count);
+  // [recomp fix: font-glyph striping — KB 65, ironclad] force_upload bypasses the per-page
+  // "already valid -> skip upload" optimization and re-uploads every requested page EXCEPT pages
+  // the GPU itself wrote (those stay protected so GPU-produced data is not clobbered by stale CPU
+  // memory — clobbering them regresses the boot to a black screen).
+  // The texture cache passes true: it only calls this when a texture is already known outdated
+  // (its own watch fired), so the data MUST be refetched in full. Trusting the page-valid flags
+  // there raced the host write-watch (some CPU-rasterized glyph pages read "valid" though their
+  // bytes had changed) -> the GPU sampled stale bytes -> vertical-striped text. Vertex/index and
+  // other GPU reads keep force_upload=false (the optimization is safe and wanted for them).
+  bool RequestRanges(const std::pair<uint32_t, uint32_t>* ranges, size_t count,
+                     bool force_upload = false);
   bool RequestRange(uint32_t start, uint32_t length);
 
   // Marks the range and, if not exact_range, potentially its surroundings
@@ -196,6 +206,15 @@ class SharedMemory {
   std::atomic<uint64_t*> staging_valid_flags_{nullptr};
   // Subset of valid pages containing data written by the GPU.
   std::vector<uint64_t> system_page_flags_valid_and_gpu_written_;
+  // [recomp fix: font-glyph striping — KB 65, ironclad] Sticky per-page "this guest page is
+  // CPU-rewritten (dynamic)" flags. Set the first time a page is invalidated by a guest CPU
+  // write (MemoryInvalidationCallback) and never cleared. RequestRanges treats a dynamic page as
+  // NOT valid, so it can never skip the page's re-upload again. This removes the dependence on
+  // every per-frame CPU glyph write tripping the host write-watch: a single missed/raced watch
+  // can no longer leave the GPU sampling stale bytes (vertical-striped text). Costs nothing for
+  // static content — the texture cache only re-requests a texture whose own watch fired, so pages
+  // that are never CPU-rewritten are never re-uploaded regardless of this flag.
+  std::vector<uint64_t> system_page_flags_dynamic_;
   // Dirty state tracking for frame-end page-state refresh.
   std::atomic<bool> gpu_written_data_dirty_{false};
   std::atomic<uint32_t> dirty_blocks_{0};
diff --git a/src/graphics/pipeline/texture/cache.cpp b/src/graphics/pipeline/texture/cache.cpp
index c7c824e..e17dd2f 100644
--- a/src/graphics/pipeline/texture/cache.cpp
+++ b/src/graphics/pipeline/texture/cache.cpp
