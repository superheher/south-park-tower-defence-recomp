 void TextureCache::RequestTextures(uint32_t used_texture_mask) {
   const auto& regs = register_file();
 
-  if (texture_became_outdated_.exchange(false, std::memory_order_acquire)) {
+  bool bindings_need_reset = texture_became_outdated_.exchange(false, std::memory_order_acquire);
+
+  // [recomp fix: font-glyph striping — KB 65, ironclad pt3] Re-mark recently CPU-written bound
+  // textures outdated for a couple of frames so a glyph memcpy that settled after the one-shot
+  // write-watch already fired (mid-write load -> striped tail, loads=1) is reloaded once complete.
+  // Cheap: only bound textures with a pending recheck, and the count is bounded per write event.
+  {
+    auto global_lock = global_critical_region_.Acquire();
+    for (TextureBinding& binding : texture_bindings_) {
+      if (binding.texture && binding.texture->ConsumeBaseRecheckFrame(global_lock)) {
+        bindings_need_reset = true;
+      }
+      if (binding.texture_signed && binding.texture_signed->ConsumeBaseRecheckFrame(global_lock)) {
+        bindings_need_reset = true;
+      }
+    }
+  }
+
+  if (bindings_need_reset) {
     // A texture has become outdated - make sure whether textures are outdated
     // is rechecked in this draw and in subsequent ones to reload the new data
     // if needed.
@@ -569,8 +587,12 @@ void TextureCache::RequestTextures(uint32_t used_texture_mask) {
     for (const PendingSharedMemoryRange& pending_range : pending_shared_memory_ranges) {
       pending_shared_memory_range_pairs.emplace_back(pending_range.start, pending_range.length);
     }
+    // [recomp fix: font-glyph striping — KB 65, ironclad] force_upload=true: these textures are
+    // being (re)loaded because they are outdated, so fetch their full contents fresh rather than
+    // trusting the racy per-page valid flags (which left dynamic glyph pages stale -> striping).
     batched_shared_memory_request_succeeded = shared_memory().RequestRanges(
-        pending_shared_memory_range_pairs.data(), pending_shared_memory_range_pairs.size());
+        pending_shared_memory_range_pairs.data(), pending_shared_memory_range_pairs.size(),
+        /*force_upload=*/true);
   }
 
   if (batched_shared_memory_request_succeeded) {
@@ -656,6 +678,10 @@ TextureCache::Texture::Texture(TextureCache& texture_cache, const TextureKey& ke
   outdated_mask_.store(
       (base_outdated_ ? kOutdatedBitBase : 0) | (mips_outdated_ ? kOutdatedBitMips : 0),
       std::memory_order_relaxed);
+  // [recomp fix: font-glyph striping — KB 65, ironclad pt3] Arm the settle-recheck for the initial
+  // base load: a CPU-rasterized texture (e.g. the in-match hint banner) is frequently created while
+  // the guest is still writing its glyph bytes, so the first load captures a stale tail.
+  base_arm_recheck_on_load_ = base_outdated_;
 }
 
 TextureCache::Texture::~Texture() {
@@ -691,6 +717,17 @@ void TextureCache::Texture::MakeUpToDateAndWatch(
     base_watch_handle_ = shared_memory.WatchMemoryRange(
         key().base_page << 12, GetGuestBaseSize(), TextureCache::WatchCallback, this, nullptr, 0);
     outdated_mask_.fetch_and(~kOutdatedBitBase, std::memory_order_release);
+    // [recomp fix: font-glyph striping — KB 65, ironclad pt3] If this load was triggered by a real
+    // reason (creation or a guest write) rather than by a forced recheck, schedule a couple of extra
+    // reloads. The one-shot write-watch + wide invalidation can let a multi-page glyph memcpy finish
+    // AFTER this upload read the pages but BEFORE protection was re-armed, with no further fault -> a
+    // stale striped tail that would otherwise never reload (loads=1). The forced rechecks don't set
+    // base_arm_recheck_on_load_, so this cannot loop.
+    if (base_arm_recheck_on_load_) {
+      base_arm_recheck_on_load_ = false;
+      base_recheck_frames_ = 3;
+      base_recheck_last_submission_ = texture_cache().current_submission_index_;
+    }
   }
   if (mips_outdated_) {
     assert_not_zero(GetGuestMipsSize());
@@ -740,7 +777,28 @@ void TextureCache::Texture::WatchCallback(
     base_outdated_ = true;
     base_watch_handle_ = nullptr;
     outdated_mask_.fetch_or(kOutdatedBitBase, std::memory_order_release);
+    // [recomp fix: font-glyph striping — KB 65, ironclad pt3] Mark that this outdating came from a
+    // real guest CPU write so the next load arms the settle-recheck (see MakeUpToDateAndWatch).
+    base_arm_recheck_on_load_ = true;
+  }
+}
+
+bool TextureCache::Texture::ConsumeBaseRecheckFrame(
+    [[maybe_unused]] const std::unique_lock<std::recursive_mutex>& global_lock) {
+  if (base_recheck_frames_ == 0) {
+    return false;
+  }
+  // Only consume one recheck per GPU submission, so the forced reloads are spread across real
+  // frames rather than several draws within a single frame (which could all still race the memcpy).
+  uint64_t submission = texture_cache_.current_submission_index_;
+  if (submission == base_recheck_last_submission_) {
+    return false;
   }
+  base_recheck_last_submission_ = submission;
+  --base_recheck_frames_;
+  base_outdated_ = true;
+  outdated_mask_.fetch_or(kOutdatedBitBase, std::memory_order_release);
+  return true;
 }
 
 void TextureCache::WatchCallback(const std::unique_lock<std::recursive_mutex>& global_lock,
@@ -888,7 +946,10 @@ bool TextureCache::LoadTextureData(Texture& texture) {
   for (size_t i = 0; i < pending_range_count; ++i) {
     pending_range_pairs[i] = std::make_pair(pending_ranges[i].start, pending_ranges[i].length);
   }
-  if (!shared_memory().RequestRanges(pending_range_pairs, pending_range_count)) {
+  // [recomp fix: font-glyph striping — KB 65, ironclad] force_upload=true (see RequestTextures):
+  // a texture reaching here is outdated, so re-upload it in full instead of trusting valid flags.
+  if (!shared_memory().RequestRanges(pending_range_pairs, pending_range_count,
+                                     /*force_upload=*/true)) {
     return false;
   }
 
