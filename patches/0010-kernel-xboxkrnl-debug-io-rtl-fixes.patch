 namespace rex::kernel::xboxkrnl {
 using namespace rex::system;
 
+// [recomp] Hide the Xbox Live Arcade boot logo (ArcadeLogo.ptc). Its frames are JPEG-compressed
+// in the source asset, so the full-screen splash shows blocky/ringing artifacts. With this set,
+// NtCreateFile reports it as not-found -> the game shows black and proceeds. Default off.
+REXCVAR_DEFINE_BOOL(skip_arcade_logo, false, "Game",
+                    "Skip the Xbox Live Arcade boot logo (ArcadeLogo.ptc); shows black instead.");
+
 struct CreateOptions {
   // https://processhacker.sourceforge.io/doc/ntioapi_8h.html
   static const uint32_t FILE_DIRECTORY_FILE = 0x00000001;
@@ -100,6 +107,41 @@ static bool IsValidPath(const std::string_view s, bool is_pattern) {
   return true;
 }
 
+// [recomp locale-fallback] The retail disc lays localized assets under a locale
+// subdirectory (e.g. ...\Frontend\Graphics\en-en\foo.png or ...\Movies\en-en\bar.wmv),
+// but our extracted asset tree flattened them into the parent directory. When an open
+// fails, NtCreateFile retries once with a locale-looking path component (xx-yy: two
+// ASCII letters / '-' / two ASCII letters) removed, so the base asset is served. This
+// makes the previously-manual "movie en-en hardlink" setup step automatic and general
+// (covers the campaign slides/diagrams, the intro/level movies, etc.). Only the first
+// such middle component is stripped. Returns true and fills `out` on a match.
+static bool TryStripLocaleSegment(const std::string& path, std::string* out) {
+  auto is_alpha = [](char c) { return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z'); };
+  const size_t n = path.size();
+  size_t i = 0;
+  while (i < n) {
+    size_t start = i;
+    size_t end = start;
+    while (end < n && path[end] != '\\' && path[end] != '/') {
+      ++end;
+    }
+    // A locale tag is a *middle* directory component: a separator precedes it
+    // (start > 0) and one follows it (end < n), and it is exactly "xx-yy".
+    if (start > 0 && end < n && (end - start) == 5 && is_alpha(path[start]) &&
+        is_alpha(path[start + 1]) && path[start + 2] == '-' && is_alpha(path[start + 3]) &&
+        is_alpha(path[start + 4])) {
+      out->assign(path, 0, start);                    // prefix incl. the separator before the tag
+      out->append(path, end + 1, std::string::npos);  // skip the tag and its trailing separator
+      return true;
+    }
+    if (end >= n) {
+      break;
+    }
+    i = end + 1;
+  }
+  return false;
+}
+
 u32 NtCreateFile_entry(mapped_u32 handle_out, u32 desired_access,
                        ppc_ptr_t<X_OBJECT_ATTRIBUTES> object_attrs,
                        ppc_ptr_t<X_IO_STATUS_BLOCK> io_status_block, mapped_u64 allocation_size_ptr,
@@ -133,6 +175,18 @@ u32 NtCreateFile_entry(mapped_u32 handle_out, u32 desired_access,
     return X_STATUS_OBJECT_NAME_INVALID;
   }
 
+  // [recomp] Optionally hide the Xbox Live Arcade boot logo (its JPEG frames look blocky
+  // full-screen): report ArcadeLogo.ptc as not-found so the game shows black and continues.
+  if (REXCVAR_GET(skip_arcade_logo) && target_path.find("ArcadeLogo") != std::string::npos) {
+    REXKRNL_INFO("[NtCreateFile] skip_arcade_logo: hiding '{}'", target_path);
+    *handle_out = X_INVALID_HANDLE_VALUE;
+    if (io_status_block) {
+      io_status_block->status = X_STATUS_NO_SUCH_FILE;
+      io_status_block->information = 0;
+    }
+    return X_STATUS_NO_SUCH_FILE;
+  }
+
   if (object_attrs->root_directory != 0xFFFFFFFD &&  // ObDosDevices
       object_attrs->root_directory != 0) {
     auto root_file = REX_KERNEL_OBJECTS()->LookupObject<XFile>(object_attrs->root_directory);
@@ -149,6 +203,29 @@ u32 NtCreateFile_entry(mapped_u32 handle_out, u32 desired_access,
       root_entry, target_path, rex::filesystem::FileDisposition((uint32_t)creation_disposition),
       desired_access, (create_options & CreateOptions::FILE_DIRECTORY_FILE) != 0,
       (create_options & CreateOptions::FILE_NON_DIRECTORY_FILE) != 0, &vfs_file, &file_action);
+
+  // [recomp locale-fallback] If a pure open failed and the path carries a locale subdir
+  // (xx-yy) that the flattened extraction dropped, retry once at the parent directory.
+  if (XFAILED(result) && !root_entry &&
+      (uint32_t)creation_disposition == (uint32_t)rex::filesystem::FileDisposition::kOpen) {
+    std::string fallback_path;
+    if (TryStripLocaleSegment(target_path, &fallback_path)) {
+      rex::filesystem::File* fb_file = nullptr;
+      rex::filesystem::FileAction fb_action;
+      X_STATUS fb_result = REX_KERNEL_FS()->OpenFile(
+          root_entry, fallback_path, rex::filesystem::FileDisposition::kOpen, desired_access,
+          (create_options & CreateOptions::FILE_DIRECTORY_FILE) != 0,
+          (create_options & CreateOptions::FILE_NON_DIRECTORY_FILE) != 0, &fb_file, &fb_action);
+      if (XSUCCEEDED(fb_result)) {
+        REXKRNL_INFO("[NtCreateFile] locale-fallback: served '{}' for '{}'", fallback_path,
+                     target_path);
+        result = fb_result;
+        vfs_file = fb_file;
+        file_action = fb_action;
+      }
+    }
+  }
+
   object_ref<XFile> file = nullptr;
 
   X_HANDLE handle = X_INVALID_HANDLE_VALUE;
