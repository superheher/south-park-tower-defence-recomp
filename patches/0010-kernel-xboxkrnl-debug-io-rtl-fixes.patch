 void RtlRaiseException_entry(ppc_ptr_t<X_EXCEPTION_RECORD> record) {
-  switch (record->code) {
-    case 0x406D1388: {
-      HandleSetThreadName(record);
-      return;
-    }
-    case 0xE06D7363: {
-      HandleCppException(record);
-      return;
-    }
+  // 0x406D1388 = MS_VC_EXCEPTION (SetThreadName debugger notification) — not a real
+  // exception; just record the name and return.
+  if (record->code == 0x406D1388) {
+    HandleSetThreadName(record);
+    return;
   }
-
-  // TODO(benvanik): unwinding.
-  // This is going to suck.
-  rex::debug::Break();
+  // Any real guest exception (C++ throw 0xE06D7363, or other status) must PROPAGATE.
+  // Previously this fell through to rex::debug::Break() (abort/no-op), so the guest's
+  // recompiled CRT then ran its own manual SEH dispatch (RtlDispatchException ->
+  // ... -> RtlRestoreContext/sub_8242EA70), whose non-local jump the static recomp
+  // can't perform -> register corruption -> guest-null write -> worker dies -> hang.
+  // Raise it as a host exception so the nearest generated SEH_CATCH_ALL handles it
+  // (recover-to-caller failure), bypassing the broken manual dispatch. See KB
+  // titles/south-park-lgtdp/40-seh-implementation-plan.md.
+  REXKRNL_WARN("RtlRaiseException code=0x{:08X}: raising guest SEH to nearest handler",
+               static_cast<uint32_t>(record->code));
+  rex::platform::seh_raise_guest_unwind();
 }
 
