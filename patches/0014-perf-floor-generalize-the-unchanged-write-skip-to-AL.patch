From b3d8ebed0e5248a494e3f05e430443185d1a9428 Mon Sep 17 00:00:00 2001
From: superheher <heh@vivaldi.net>
Date: Sat, 30 May 2026 18:57:26 +0300
Subject: [PATCH] perf(floor): generalize the unchanged-write skip to ALL
 pure-state registers

The constant-only skip (patch 13) covered ~half the redundant register writes.
New per-register instrumentation of a heavy-combat CP dip showed ~90% of EVERY
per-register write re-stores the value the register already holds -- the title
re-sets the same render state (RB_*/PA_*/SQ_*/VGT_* in 0x2xxx) + flush-fetch
(0x5000-2) every draw, not just constants.

Replace the constant-range skip in VulkanCommandProcessor::WriteRegister with a
generic one: skip any unchanged-value write whose register has NO eager write
side effect. The must-not-skip set (RegisterWriteHasSideEffect) is the exhaustive,
adversarially-verified 8-entry blocklist -- SCRATCH range (guest-memory writeback),
COHER_STATUS_HOST (dirty-OR + MakeCoherent arm), the four DC_LUT gamma-ramp
state-machine regs, and the fetch-constant range (texture-cache / vertex-residency
invalidation). Everything else is pure state read lazily at draw time, so an
unchanged write is a behavioral no-op.

Clears the +1.0 keep-bar vs bothfix (median p10 +1.1 / +3.3 across two A/B runs),
min rises 10-12 -> 14-15, gate-pass + mid-combat render-verified. The best-measured
combat-floor lever of the campaign. A follow-on TYPE0 dispatch-skip (skip the
virtual call too) was measured floor-neutral and dropped. See
docs/FLOOR-CP-ELISION-REPORT.md.
---
 src/graphics/vulkan/command_processor.cpp | 45 ++++++++++++++++-------
 1 file changed, 32 insertions(+), 13 deletions(-)

diff --git a/src/graphics/vulkan/command_processor.cpp b/src/graphics/vulkan/command_processor.cpp
index de3a8c9..1e4561d 100644
--- a/src/graphics/vulkan/command_processor.cpp
+++ b/src/graphics/vulkan/command_processor.cpp
@@ -2136,20 +2136,39 @@ void VulkanCommandProcessor::ShutdownContext() {
   CommandProcessor::ShutdownContext();
 }
 
+// True iff a write to `index` has an EAGER side effect beyond storing into register_file_->values[],
+// so a redundant (unchanged-value) write to it must NOT be elided. This is the exhaustive, adversarially
+// verified must-not-skip set for the Vulkan CP write path (base CP + Vulkan override):
+//   * SCRATCH_REG0..7        (0x0578-0x057F) -- guest-memory writeback (interrupt-sync handshake)
+//   * COHER_STATUS_HOST      (0x0A31)        -- |= 0x80000000 dirty-OR that arms MakeCoherent()
+//   * DC_LUT_RW_INDEX..30_COLOR (0x1922-0x1925) -- gamma-ramp sequential FIFO state machine
+//   * SHADER_CONSTANT_FETCH_* (0x4800-0x48BF) -- texture-cache + vertex-buffer-residency invalidation
+// Everything else (render state 0x2xxx, flush-fetch 0x5000-2, float/bool/loop constants, ...) is pure
+// state read lazily at draw time, so an unchanged write is a behavioral no-op.
+static inline bool RegisterWriteHasSideEffect(uint32_t index) {
+  return (index >= XE_GPU_REG_SHADER_CONSTANT_FETCH_00_0 &&
+          index <= XE_GPU_REG_SHADER_CONSTANT_FETCH_31_5) ||
+         (index >= XE_GPU_REG_SCRATCH_REG0 && index <= XE_GPU_REG_SCRATCH_REG7) ||
+         (index >= XE_GPU_REG_DC_LUT_RW_INDEX && index <= XE_GPU_REG_DC_LUT_30_COLOR) ||
+         index == XE_GPU_REG_COHER_STATUS_HOST;
+}
+
 void VulkanCommandProcessor::WriteRegister(uint32_t index, uint32_t value) {
-  // [perf] Skip unchanged float / bool / loop shader-constant writes. These registers are PURE GPU
-  // state with no write side effect, so re-writing the value the register already holds is a no-op
-  // for the base store AND for the constant-buffer dirty-mark below (the GPU already has it). Heavy
-  // combat re-sets large constant ranges every draw, much of it identical, and WriteRegister was the
-  // single hottest CP function during a dip (~11% of all cycles) -- so skipping the redundant ones
-  // cuts real PM4->Vulkan translation time (the measured combat-floor bottleneck). The fetch-constant
-  // range is intentionally NOT short-circuited: its writes have side effects (texture cache /
-  // vertex-buffer residency invalidation) that must run even on an unchanged value.
-  if (index < RegisterFile::kRegisterCount &&
-      ((index >= XE_GPU_REG_SHADER_CONSTANT_000_X && index <= XE_GPU_REG_SHADER_CONSTANT_511_W) ||
-       (index >= XE_GPU_REG_SHADER_CONSTANT_BOOL_000_031 &&
-        index <= XE_GPU_REG_SHADER_CONSTANT_LOOP_31)) &&
-      register_file_->values[index] == value) {
+  // [perf] Generic redundant-write elision. Per-frame instrumentation of a heavy-combat CP dip showed
+  // WriteRegister is the single hottest CP function (~11% of CP cycles) and that ~90% of ALL incoming
+  // per-register writes re-write the value the register already holds -- the title re-sets the same
+  // render state (RB_*/PA_*/SQ_*/VGT_* in 0x2xxx), flush-fetch (0x5000-2) and shader constants every
+  // draw. For a PURE-STATE register -- one whose write only stores into register_file_->values[] and
+  // is consumed LAZILY at draw time (snapshot compare) -- re-writing the held value is a behavioral
+  // no-op, so we return early and skip the store, the base side-effect switch, and the constant
+  // dirty-mark below. The ONLY registers whose write has an EAGER side effect (enumerated and
+  // adversarially verified) and must NOT be skipped are the 8 covered by RegisterWriteHasSideEffect():
+  // the SCRATCH range (guest-memory writeback), COHER_STATUS_HOST (dirty-OR + cache-invalidation arm),
+  // the four DC_LUT gamma-ramp state-machine regs, and the fetch-constant range (texture-cache /
+  // vertex-residency invalidation). This supersedes the earlier constant-only skip (the float/bool/
+  // loop constant ranges are pure state, so they remain covered here).
+  if (index < RegisterFile::kRegisterCount && register_file_->values[index] == value &&
+      !RegisterWriteHasSideEffect(index)) {
     return;
   }
 
-- 
